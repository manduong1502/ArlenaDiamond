<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    <link rel="icon" type="image/png" href="{{ 'logo_arlena.png' | asset_url }}">
    <link rel="apple-touch-icon" href="{{ 'logo_arlena.png' | asset_url }}">

    {{ content_for_header }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous">
    {{ 'style.css' | asset_url | stylesheet_tag }}

  </head>

  <body>
    {% section 'header' %}

    {{ content_for_layout }}

    {% section 'footer' %}
    {% render 'newsletter-popup' %}
    <script src="{{ 'main.js' | asset_url }}" type="module" defer="defer"></script>
    <script src="{{ 'wishlist.js' | asset_url }}" defer></script>

    {% if template.name == 'index' %}
    <!-- Homepage Intro Overlay -->
    <div id="intro-overlay"></div>
    <script>
      (function () {
        var overlay = document.getElementById('intro-overlay');
        if (!overlay) return;

        // Bắt đầu fade out sau 50ms, transition 1.95s → tổng ~2 giây
        setTimeout(function () {
          overlay.style.backdropFilter = 'blur(0px)';
          overlay.style.webkitBackdropFilter = 'blur(0px)';
          overlay.style.background = 'rgba(255,255,255,0)';
          overlay.style.opacity = '0';
          overlay.style.pointerEvents = 'none';

          // Sau khi animation xong: ẩn overlay + hạ z-index sticky logo
          // để header (z-index:100) luôn nằm trên khi scroll bình thường
          setTimeout(function () {
            overlay.style.display = 'none';
            var stickyWrapper = document.querySelector('.sticky-wrapper');
            if (stickyWrapper) {
              stickyWrapper.style.zIndex = '1'; // dưới header (100)
            }
          }, 2000);
        }, 50);
      })();
    </script>
    {% endif %}
  </body>
</html>
