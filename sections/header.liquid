<!-- CART OVERLAY -->
<div class="cart-overlay" id="cartOverlay">
  <!-- Header -->
  <div
    class="cart-header"
    style="display: flex; justify-content: space-between; padding: 20px; border-bottom: 1px solid #000; font-size: 11px; text-transform: uppercase; font-weight: bold;"
  >
    <span style="letter-spacing: 1px;"
      >BAG
      <span class="cart-header-count" style="margin-left: 15px;">{{ cart.item_count | pad_left: 2, '0' }}</span></span
    >
    <span id="closeCart" style="color: #000; cursor: pointer; letter-spacing: 0.5px;">X CLOSE</span>
  </div>

  <div class="cart-body" style="display: flex; flex-direction: column; height: calc(100vh - 55px);">
    <!-- Product List -->
    <div class="cart-items" style="flex: 1; overflow-y: auto; width: 100%;">
      {% for item in cart.items %}
        <div
          class="cart-item"
          style="display: flex; flex-direction: column; width: 100%; font-size: 11px; text-transform: uppercase; border-bottom: 1px solid #000;"
        >
          <div style="display: flex; justify-content: space-between; padding: 10px;">
            <a href="{{ item.url }}" style="color: #000; text-decoration: none; font-weight: 600;">
              {{- item.product.title -}}
            </a>
            <span style="color: #000;">{{ item.final_line_price | money_without_trailing_zeros }}</span>
          </div>
          <div style="display: flex; gap: 15px;">
            <div style="width: 120px; height: 160px; flex-shrink: 0; background: #f4f4f4; display: flex; align-items: center; justify-content: center;">
              {% if item.image %}
                <img src="{{ item.image | img_url: '400x' }}" style="width: 100%; height: 100%; object-fit: cover;">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <div style="flex: 1; display: flex; flex-direction: column; padding: 8px 0;">
              {% unless item.product.has_only_default_variant %}
                {% for option in item.options_with_values %}
                  <div style="margin-bottom: 6px; color: #555;">
                    {{ option.name | upcase }}: {{ option.value | upcase }}
                  </div>
                {% endfor %}
              {% endunless %}

              <div style="display: flex; align-items: center; margin-top: auto; border: 1px solid #e0e0e0; width: fit-content;">
                <button
                  onclick="cartChangeQty({{ forloop.index }}, {{ item.quantity | minus: 1 }})"
                  style="width: 32px; height: 32px; cursor: pointer; border: none; background: none; font-size: 16px; color: #000;"
                >
                  –
                </button>
                <span style="width: 36px; text-align: center; font-size: 13px;">{{ item.quantity }}</span>
                <button
                  onclick="cartChangeQty({{ forloop.index }}, {{ item.quantity | plus: 1 }})"
                  style="width: 32px; height: 32px; cursor: pointer; border: none; background: none; font-size: 16px; color: #000;"
                >
                  +
                </button>
              </div>
            </div>
          </div>
          <div style="display: flex; justify-content: flex-end; padding: 8px 10px;">
            <button
              onclick="cartChangeQty({{ forloop.index }}, 0)"
              style="background: none; border: none; cursor: pointer; font-size: 11px; color: #000; text-transform: uppercase; letter-spacing: 0.5px; text-decoration: underline;"
            >
              REMOVE
            </button>
          </div>
        </div>
      {% else %}
        <div style="font-size: 11px; border-bottom: 1px solid #000; padding: 15px 20px; text-transform: uppercase;">
          YOUR SHOPPING BAG IS EMPTY
        </div>
        {% unless customer %}
          <div style="padding: 15px 20px; font-size: 11px;">
            <p style="margin-bottom: 5px;">Missing items in your cart?</p>
            <p style="margin-bottom: 20px;">Sign in to see items you added before.</p>
            <div style="display: flex; gap: 60px;">
              <a href="/account/login" style="color: #000; text-decoration: underline; text-transform: uppercase;"
                >SIGN IN</a
              >
              <a href="/account/register" style="color: #000; text-decoration: underline; text-transform: uppercase;"
                >REGISTER</a
              >
            </div>
          </div>
        {% endunless %}
      {% endfor %}
    </div>

    <!-- Checkout Footer -->
    <div class="cart-footer" style="font-size: 11px;">
      <div style="padding: 15px 20px; border-bottom: 1px solid #000; border-top: 1px solid #000;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-weight: bold;">
          <span style="text-transform: uppercase;">SHIPPING</span>
          <span>FREE</span>
        </div>
        <div style="color: #666; text-transform: none; line-height: 1.4;">
          Australia Post Standard Estimated delivery within 2-4 business days
        </div>
      </div>

      <div style="padding: 15px 20px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; text-transform: uppercase; font-weight: bold;">
          <span>TOTAL</span>
          <span class="cart-total-price">{{ cart.total_price | money_without_trailing_zeros }}</span>
        </div>
        <div style="color: #666; text-transform: none; margin-bottom: 20px; line-height: 1.4;">
          Incl. VAT and import duties.
        </div>

        <!-- Checkout button: show by default if cart has items -->
        <a
          id="cart-checkout-btn"
          href="/checkout"
          style="{% if cart.item_count == 0 %}display: none;{% else %}display: block;{% endif %} width: 100%; background: #000; color: #fff; padding: 16px; font-weight: bold; font-size: 11px; letter-spacing: 0.5px; cursor: pointer; text-transform: uppercase; text-align: center; text-decoration: none; box-sizing: border-box;"
          >CHECKOUT</a
        >

        <!-- Payment Icons -->
        <div style="margin-top: 20px; padding: 0;">
          <div style="font-weight: bold; text-transform: uppercase; margin-bottom: 10px;">PAYMENT</div>
          <div style="display: flex; justify-content: flex-start; gap: 8px; align-items: center;">
            <span class="payment-badge payment-badge--dark" style="width:50px;height:30px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #222;border-radius:4px;overflow:hidden;">
              <img src="{{ 'Apple_Pay_logo.svg.png' | asset_url }}" alt="Apple Pay" style="max-height:18px;max-width:36px;width:auto;height:auto;object-fit:contain;">
            </span>
            <span style="width:50px;height:30px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ccc;border-radius:4px;overflow:hidden;">
              <img src="{{ 'Mastercard-logo.svg.png' | asset_url }}" alt="Mastercard" style="max-height:18px;max-width:36px;width:auto;height:auto;object-fit:contain;">
            </span>
            <span style="width:50px;height:30px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ccc;border-radius:4px;overflow:hidden;">
              <img src="{{ 'visa-logo.png' | asset_url }}" alt="Visa" style="max-height:18px;max-width:36px;width:auto;height:auto;object-fit:contain;">
            </span>
            <span style="width:50px;height:30px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ccc;border-radius:4px;overflow:hidden;">
              <img src="{{ 'PayPal.svg.png' | asset_url }}" alt="PayPal" style="max-height:18px;max-width:36px;width:auto;height:auto;object-fit:contain;">
            </span>
            <span style="display:inline-flex;align-items:center;padding:0;">
              <img src="{{ 'Afterpay_Mint_Logo.jpg' | asset_url }}" alt="Afterpay" style="height:30px;width:auto;border-radius:4px;">
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  /* ── CART AJAX HELPERS (global, used by all pages) ── */
  function cartFormatMoney(cents) {
    return 'A$' + Math.round(cents / 100).toLocaleString('en-AU');
  }

  function cartRenderItems(cart) {
    var container = document.querySelector('.cart-items');
    var headerCount = document.querySelector('.cart-header-count');
    var totalEl = document.querySelector('.cart-total-price');
    var badge = document.querySelector('.cart-badge');
    var cartBtn = document.getElementById('cartBtn');

    if (headerCount) headerCount.textContent = String(cart.item_count).padStart(2, '0');
    if (totalEl) totalEl.textContent = cartFormatMoney(cart.total_price);

    // Badge
    if (cart.item_count > 0) {
      if (badge) {
        badge.textContent = cart.item_count;
      } else if (cartBtn) {
        var b = document.createElement('span');
        b.className = 'cart-badge';
        b.textContent = cart.item_count;
        cartBtn.appendChild(b);
      }
    } else {
      if (badge) badge.remove();
    }

    if (!container) return;
    var checkoutBtn = document.getElementById('cart-checkout-btn');
    if (cart.items.length === 0) {
      container.innerHTML =
        '<div style="font-size:11px;border-bottom:1px solid #000;padding:15px 20px;text-transform:uppercase;">YOUR SHOPPING BAG IS EMPTY</div>';
      if (checkoutBtn) checkoutBtn.style.display = 'none';
      return;
    }
    if (checkoutBtn) checkoutBtn.style.display = 'block';

    var html = '';
    cart.items.forEach(function (item, idx) {
      var line = idx + 1;
      var imgHtml = item.image
        ? '<img src="' + item.image + '" style="width:100%;height:100%;object-fit:cover;" />'
        : '';
      var optHtml = '';
      item.options_with_values.forEach(function (o) {
        if (o.value !== 'Default Title')
          optHtml +=
            '<div style="margin-bottom:6px;color:#555;">' +
            o.name.toUpperCase() +
            ': ' +
            o.value.toUpperCase() +
            '</div>';
      });
      html +=
        '<div class="cart-item" style="display:flex;flex-direction:column;width:100%;font-size:11px;text-transform:uppercase;border-bottom:1px solid #000;">' +
        '<div style="display:flex;justify-content:space-between;padding:10px;">' +
        '<a href="' +
        item.url +
        '" style="color:#000;text-decoration:none;font-weight:600;">' +
        item.product_title +
        '</a>' +
        '<span>' +
        cartFormatMoney(item.final_line_price) +
        '</span></div>' +
        '<div style="display:flex;gap:15px;">' +
        '<div style="width:120px;height:160px;flex-shrink:0;background:#f4f4f4;display:flex;align-items:center;justify-content:center;">' +
        imgHtml +
        '</div>' +
        '<div style="flex:1;display:flex;flex-direction:column;padding:8px 0;">' +
        optHtml +
        '<div style="display:flex;align-items:center;margin-top:auto;border:1px solid #e0e0e0;width:fit-content;">' +
        '<button onclick="cartChangeQty(' +
        line +
        ',' +
        (item.quantity - 1) +
        ')" style="width:32px;height:32px;cursor:pointer;border:none;background:none;font-size:16px;color:#000;">–</button>' +
        '<span style="width:36px;text-align:center;font-size:13px;">' +
        item.quantity +
        '</span>' +
        '<button onclick="cartChangeQty(' +
        line +
        ',' +
        (item.quantity + 1) +
        ')" style="width:32px;height:32px;cursor:pointer;border:none;background:none;font-size:16px;color:#000;">+</button>' +
        '</div></div></div>' +
        '<div style="display:flex;justify-content:flex-end;padding:8px 10px;">' +
        '<button onclick="cartChangeQty(' +
        line +
        ',0)" style="background:none;border:none;cursor:pointer;font-size:11px;color:#000;text-transform:uppercase;letter-spacing:0.5px;text-decoration:underline;">REMOVE</button>' +
        '</div></div>';
    });
    container.innerHTML = html;
  }

  window.cartChangeQty = function (line, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty }),
    })
      .then(function (r) {
        return r.json();
      })
      .then(function (cart) {
        cartRenderItems(cart);
      });
  };
</script>

