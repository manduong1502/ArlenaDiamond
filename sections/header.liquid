  .search-overlay__title {
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 2px;
    color: #ffffff;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .search-overlay__close {
    background: none;
    border: none;
    color: #c5a880;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .search-overlay__close:hover {
    color: #ffffff;
  }
  .search-overlay__body {
    max-width: 800px;
    width: 90%;
    margin: 40px auto 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .search-overlay__input-wrapper {
    position: relative;
    width: 100%;
    margin-bottom: 30px;
  }
  .search-overlay__input {
    width: 100%;
    background: #181818;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50px;
    padding: 16px 24px 16px 54px;
    font-size: 15px;
    color: #fff;
    outline: none;
    transition: border-color 0.3s ease;
  }
  .search-overlay__input:focus {
    border-color: #c5a880;
  }
  .search-overlay__icon {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: #c5a880;
    font-size: 18px;
  }
  .search-quick-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 35px;
  }
  .search-pill-item {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    color: #ddd;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .search-pill-item:hover {
    border-color: #c5a880;
    color: #c5a880;
    background: rgba(197, 168, 128, 0.1);
  }
</style>

<!-- CART OVERLAY -->
<div class="cart-overlay" id="cartOverlay">
  <!-- Header -->
  <div class="cart-header">
    <div class="cart-header-title">
      <i class="fa-solid fa-bag-shopping" style="color:#c5a880; margin-right:8px; font-size:16px;"></i>
      <span>SHOPPING BAG</span>
      <span class="cart-header-count" style="margin-left: 8px; color: #c5a880;">({{ cart.item_count }})</span>
    </div>
    <button class="cart-header-close" id="closeCart">
      <span>CLOSE</span>
      <i class="fa-solid fa-xmark" style="font-size:16px;"></i>
    </button>
  </div>

  <div class="cart-body">
    <!-- Product List -->
    <div class="cart-items">
      {% for item in cart.items %}
        <div class="cart-item-card">
          <div class="cart-item-main">
            <div class="cart-item-img-wrap">
              {% if item.image %}
                <img src="{{ item.image | img_url: '300x' }}" alt="{{ item.product.title | escape }}">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <div class="cart-item-info">
              <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
              {% unless item.product.has_only_default_variant %}
                {% for option in item.options_with_values %}
                  <div class="cart-item-option">{{ option.name }}: {{ option.value }}</div>
                {% endfor %}
              {% endunless %}
              <div class="cart-item-price" style="margin-top:auto;">{{ item.final_line_price | money_without_trailing_zeros }}</div>
            </div>
          </div>
          <div class="cart-item-bottom">
            <div class="cart-qty-ctrl">
              <button class="cart-qty-btn" onclick="cartChangeQty({{ forloop.index }}, {{ item.quantity | minus: 1 }})">–</button>
              <span class="cart-qty-num">{{ item.quantity }}</span>
              <button class="cart-qty-btn" onclick="cartChangeQty({{ forloop.index }}, {{ item.quantity | plus: 1 }})">+</button>
            </div>
            <button class="btn-remove-item" onclick="cartChangeQty({{ forloop.index }}, 0)" title="Remove item">
              <i class="fa-regular fa-trash-can"></i>
            </button>
          </div>
        </div>
      {% else %}
        <div class="empty-cart-container">
          <div class="empty-cart-icon-circle">
            <i class="fa-solid fa-gem"></i>
          </div>
          <div class="empty-cart-title">YOUR SHOPPING BAG IS EMPTY</div>
          <div class="empty-cart-desc">Explore our handcrafted fine jewellery collection, made to order with precision in Australia.</div>
          <a href="/collections/engagement-rings" class="btn-empty-cart-primary">EXPLORE ENGAGEMENT RINGS</a>
          <a href="/collections/all" class="btn-empty-cart-secondary">SHOP ALL JEWELLERY</a>
          {% unless customer %}
            <div class="empty-cart-account-note">
              Have an account? <a href="/account/login">SIGN IN</a> to view saved items.
            </div>
          {% endunless %}
        </div>
      {% endfor %}
    </div>

    <!-- Checkout Footer -->
    <div class="cart-footer-box">
      <div class="cart-shipping-notice">
        <i class="fa-solid fa-truck-fast"></i>
        <span>FREE INSURED DELIVERY</span>
      </div>

      <div class="cart-total-row">
        <span>TOTAL</span>
        <span class="cart-total-price">{{ cart.total_price | money_without_trailing_zeros }}</span>
      </div>

      <!-- Checkout button -->
      <a
        id="cart-checkout-btn"
        href="/checkout"
        class="btn-checkout-arlena"
        style="{% if cart.item_count == 0 %}display: none;{% else %}display: block;{% endif %}"
        >PROCEED TO CHECKOUT</a
      >

      <!-- Payment Icons -->
      <div style="margin-top: 16px;">
        <div style="display: flex; justify-content: center; gap: 8px; align-items: center;">
          <span style="width:45px;height:26px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ddd;border-radius:4px;overflow:hidden;">
            <img src="{{ 'Apple_Pay_logo.svg.png' | asset_url }}" alt="Apple Pay" style="max-height:16px;max-width:32px;width:auto;height:auto;object-fit:contain;">
          </span>
          <span style="width:45px;height:26px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ddd;border-radius:4px;overflow:hidden;">
            <img src="{{ 'Mastercard-logo.svg.png' | asset_url }}" alt="Mastercard" style="max-height:16px;max-width:32px;width:auto;height:auto;object-fit:contain;">
          </span>
          <span style="width:45px;height:26px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ddd;border-radius:4px;overflow:hidden;">
            <img src="{{ 'visa-logo.png' | asset_url }}" alt="Visa" style="max-height:16px;max-width:32px;width:auto;height:auto;object-fit:contain;">
          </span>
          <span style="width:45px;height:26px;display:inline-flex;align-items:center;justify-content:center;background:#fff;border:1px solid #ddd;border-radius:4px;overflow:hidden;">
            <img src="{{ 'PayPal.svg.png' | asset_url }}" alt="PayPal" style="max-height:16px;max-width:32px;width:auto;height:auto;object-fit:contain;">
          </span>
          <span style="display:inline-flex;align-items:center;padding:0;">
            <img src="{{ 'Afterpay_Mint_Logo.jpg' | asset_url }}" alt="Afterpay" style="height:26px;width:auto;border-radius:4px;">
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  /* ── CART AJAX HELPERS (global, used by all pages) ── */
  function cartFormatMoney(cents) {
    return 'A$' + Math.round(cents / 100).toLocaleString('en-AU');
  }

  function cartRenderItems(cart) {
    var container = document.querySelector('.cart-items');
    var headerCount = document.querySelector('.cart-header-count');
    var totalEl = document.querySelector('.cart-total-price');
    var badge = document.querySelector('.cart-badge');
    var cartBtn = document.getElementById('cartBtn');

    if (headerCount) headerCount.textContent = '(' + cart.item_count + ')';
    if (totalEl) totalEl.textContent = cartFormatMoney(cart.total_price);

    // Badge
    if (cart.item_count > 0) {
      if (badge) {
        badge.textContent = cart.item_count;
      } else if (cartBtn) {
        var b = document.createElement('span');
        b.className = 'cart-badge';
        b.textContent = cart.item_count;
        cartBtn.appendChild(b);
      }
    } else {
      if (badge) badge.remove();
    }

    if (!container) return;
    var checkoutBtn = document.getElementById('cart-checkout-btn');
    if (cart.items.length === 0) {
      container.innerHTML =
        '<div class="empty-cart-container">' +
        '<div class="empty-cart-icon-circle"><i class="fa-solid fa-gem"></i></div>' +
        '<div class="empty-cart-title">YOUR SHOPPING BAG IS EMPTY</div>' +
        '<div class="empty-cart-desc">Explore our handcrafted fine jewellery collection, made to order with precision in Australia.</div>' +
        '<a href="/collections/engagement-rings" class="btn-empty-cart-primary">EXPLORE ENGAGEMENT RINGS</a>' +
        '<a href="/collections/all" class="btn-empty-cart-secondary">SHOP ALL JEWELLERY</a>' +
        '</div>';
      if (checkoutBtn) checkoutBtn.style.display = 'none';
      return;
    }
    if (checkoutBtn) checkoutBtn.style.display = 'block';

    var html = '';
    cart.items.forEach(function (item, idx) {
      var line = idx + 1;
      var imgHtml = item.image
        ? '<img src="' + item.image + '" alt="' + item.product_title + '" />'
        : '';
      var optHtml = '';
      if (item.options_with_values) {
        item.options_with_values.forEach(function (o) {
          if (o.value !== 'Default Title')
            optHtml += '<div class="cart-item-option">' + o.name + ': ' + o.value + '</div>';
        });
      }
      html +=
        '<div class="cart-item-card">' +
        '<div class="cart-item-main">' +
        '<div class="cart-item-img-wrap">' + imgHtml + '</div>' +
        '<div class="cart-item-info">' +
        '<a href="' + item.url + '" class="cart-item-title">' + item.product_title + '</a>' +
        optHtml +
        '<div class="cart-item-price" style="margin-top:auto;">' + cartFormatMoney(item.final_line_price) + '</div>' +
        '</div></div>' +
        '<div class="cart-item-bottom">' +
        '<div class="cart-qty-ctrl">' +
        '<button class="cart-qty-btn" onclick="cartChangeQty(' + line + ',' + (item.quantity - 1) + ')">–</button>' +
        '<span class="cart-qty-num">' + item.quantity + '</span>' +
        '<button class="cart-qty-btn" onclick="cartChangeQty(' + line + ',' + (item.quantity + 1) + ')">+</button>' +
        '</div>' +
        '<button class="btn-remove-item" onclick="cartChangeQty(' + line + ',0)" title="Remove item"><i class="fa-regular fa-trash-can"></i></button>' +
        '</div></div>';
    });
    container.innerHTML = html;
  }

  window.cartChangeQty = function (line, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty }),
    })
      .then(function (r) {
        return r.json();
      })
      .then(function (cart) {
        cartRenderItems(cart);
      });
  };

  /* Mobile Menu Drawer Toggle */
  document.addEventListener('DOMContentLoaded', function () {
    var mobBtn = document.getElementById('customMobileMenuBtn');
    var mobMenu = document.getElementById('mobileMenu');
    var mobClose = document.getElementById('closeMobileMenu');
    var mobBackdrop = document.getElementById('mobileMenuBackdrop');

    function openMobileDrawer() {
      if (mobMenu) mobMenu.classList.add('active');
      if (mobBackdrop) mobBackdrop.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileDrawer() {
      if (mobMenu) mobMenu.classList.remove('active');
      if (mobBackdrop) mobBackdrop.classList.remove('active');
      document.body.style.overflow = '';
    }

    if (mobBtn) {
      mobBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        openMobileDrawer();
      });
    }

    if (mobClose) {
      mobClose.addEventListener('click', function (e) {
        e.preventDefault();
        closeMobileDrawer();
      });
    }

    if (mobBackdrop) {
      mobBackdrop.addEventListener('click', function () {
        closeMobileDrawer();
      });
    }
  });
</script>

<!-- MEGA MENU OVERLAY -->
