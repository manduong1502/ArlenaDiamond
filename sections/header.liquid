<style>
  /* Announcement Bar */
  .announcement-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background-color: #000;
    color: #fff;
    padding: 8px 0;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
    z-index: 101;
    overflow: hidden;
  }
  .announcement-items {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    width: 100%;
  }
  .announcement-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-base);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .announcement-item i {
    color: #c5a880;
    font-size: 12px;
  }
  .announcement-item.mobile-dup {
    display: none;
  }

  /* Infinite Marquee Loop ONLY on Mobile */
  @media (max-width: 991px) {
    .announcement-bar {
      padding: 7px 0;
    }
    .announcement-items {
      justify-content: flex-start;
      gap: 30px;
      width: max-content;
      animation: marqueeInfinite 18s linear infinite;
    }
    .announcement-item.mobile-dup {
      display: flex;
    }
  }

  @keyframes marqueeInfinite {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Header Container */
  .header {
    position: fixed;
    top: 31px; /* announcement bar height is ~31px */
    left: 0;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 40px;
    background: #000000; /* Pure solid black background */
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    transition: padding 0.3s ease;
  }
  .header.is-scrolled {
    background: #000000;
    padding: 8px 40px;
  }
  .header__left-nav,
  .header__right-nav {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .header__left-nav {
    justify-content: flex-end;
    padding-right: 15px;
  }
  .header__left-nav #searchBtn {
    margin-right: auto;
  }
  .header__right-nav {
    justify-content: flex-start;
    padding-left: 15px;
  }
  .header__right-nav .header-icon-btn:first-of-type {
    margin-left: auto;
  }
  .header__logo-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .header__logo-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: #fff;
  }
  .header__logo-text {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: 4px;
    color: #fff;
    line-height: 1.1;
  }
  .header__logo-subtext {
    font-size: 8px;
    letter-spacing: 2px;
    color: #c5a880;
    margin-top: 3px;
    text-transform: uppercase;
  }
  .header__logo-img {
    height: 65px;
    width: auto;
    object-fit: contain;
    transition: height 0.3s ease;
  }
  .header.is-scrolled .header__logo-img {
    height: 55px;
  }

  /* Nav Links styling */
  .header-nav-link {
    font-family: var(--font-base);
    font-size: 11px;
    font-weight: 500;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    position: relative;
    padding: 5px 0;
    transition: color 0.3s ease;
  }
  .header-nav-link:hover,
  .header-nav-link.active-link {
    color: #c5a880;
  }
  .header-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 1px;
    background-color: #c5a880;
    transition: width 0.3s ease;
  }
  .header-nav-link:hover::after,
  .header-nav-link.active-link::after {
    width: 100%;
  }

  /* Header Icons */
  .header-icon-btn {
    background: transparent;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .header-icon-btn:hover {
    color: #c5a880;
  }
  .header-icon-svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  /* Mobile menu & header bar styles */
  .mobile-header-bar {
    display: none;
    width: 100%;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 8px 18px;
    background: #000000;
    position: fixed;
    top: 31px;
    left: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }
  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 85vw;
    max-width: 360px;
    height: 100vh;
    background-color: #111111;
    color: #ffffff;
    z-index: 999999;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    box-shadow: 5px 0 25px rgba(0,0,0,0.5);
  }
  .mobile-menu-overlay.active {
    transform: translateX(0) !important;
  }
  .mobile-menu-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(4px);
    z-index: 999998;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  .mobile-menu-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 991px) {
    .header {
      display: none;
    }
    .mobile-header-bar {
      display: grid;
    }
  }
</style>

