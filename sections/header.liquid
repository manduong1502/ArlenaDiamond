<style>
  /* Announcement Bar */
  .announcement-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background-color: #000;
    color: #fff;
    padding: 8px 0;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
    z-index: 101;
    overflow: hidden;
  }
  .announcement-items {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    width: 100%;
  }
  .announcement-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-base);
    text-transform: uppercase;
  }
  .announcement-item i {
    color: #c5a880;
    font-size: 12px;
  }
  @media (max-width: 991px) {
    .announcement-items {
      gap: 20px;
      overflow-x: auto;
      justify-content: flex-start;
      padding: 0 15px;
      scrollbar-width: none; /* Firefox */
    }
    .announcement-items::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
    .announcement-item {
      flex-shrink: 0;
    }
  }

  /* Header Container */
  .header {
    position: fixed;
    top: 31px; /* announcement bar height is ~31px */
    left: 0;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 40px;
    background: #000000; /* Pure solid black background */
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    transition: padding 0.3s ease;
  }
  .header.is-scrolled {
    background: #000000;
    padding: 8px 40px;
  }
  .header__left-nav,
  .header__right-nav {
    display: flex;
    align-items: center;
    gap: 25px;
  }
  .header__left-nav {
    justify-content: flex-start;
  }
  .header__right-nav {
    justify-content: flex-end;
  }
  .header__logo-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .header__logo-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: #fff;
  }
  .header__logo-text {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: 4px;
    color: #fff;
    line-height: 1.1;
  }
  .header__logo-subtext {
    font-size: 8px;
    letter-spacing: 2px;
    color: #c5a880;
    margin-top: 3px;
    text-transform: uppercase;
  }
  .header__logo-img {
    height: 65px;
    width: auto;
    object-fit: contain;
    transition: height 0.3s ease;
  }
  .header.is-scrolled .header__logo-img {
    height: 55px;
  }

  /* Nav Links styling */
  .header-nav-link {
    font-family: var(--font-base);
    font-size: 11px;
    font-weight: 500;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    position: relative;
    padding: 5px 0;
    transition: color 0.3s ease;
  }
  .header-nav-link:hover,
  .header-nav-link.active-link {
    color: #c5a880;
  }
  .header-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: #c5a880;
    transition: width 0.3s ease;
  }
  .header-nav-link:hover::after {
    width: 100%;
  }

  /* Header Icons */
  .header-icon-btn {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px;
    transition: color 0.3s ease;
  }
  .header-icon-btn:hover {
    color: #c5a880;
  }
  .header-icon-svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  /* Mobile menu styles */
  .mobile-header-bar {
    display: none;
    width: 100%;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    padding: 10px 15px;
    background: #000000;
    position: fixed;
    top: 31px;
    left: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }
  @media (max-width: 991px) {
    .header {
      display: none;
    }
    .mobile-header-bar {
      display: grid;
    }
  }
</style>

