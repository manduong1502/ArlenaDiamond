<main class="main-collection full-width">
  <style>
    /* Angara-style Collection Page Styles */
    .angara-collection {
      max-width: 1200px;
      margin: 110px auto 40px auto;
      padding: 0 20px;
      font-family: var(--font-base);
      color: #111;
    }
    @media (max-width: 991px) {
      .angara-collection {
        margin-top: 85px;
      }
    }

    /* Breadcrumbs */
    .collection-breadcrumbs {
      font-size: 11px;
      color: #666;
      letter-spacing: 0.5px;
      margin-bottom: 20px;
      text-transform: uppercase;
    }
    .collection-breadcrumbs a {
      color: #666;
      text-decoration: none;
    }
    .collection-breadcrumbs a:hover {
      color: #000;
    }
    .collection-breadcrumbs span {
      margin: 0 5px;
    }

    /* Event Banner */
    .sale-event-banner {
      width: 100%;
      background: linear-gradient(135deg, #091a3c 0%, #1e3a6d 100%);
      border: 2px solid #c5a880; /* Gold border */
      color: #fff;
      padding: 25px;
      text-align: center;
      border-radius: 4px;
      margin-bottom: 30px;
      position: relative;
      overflow: hidden;
    }
    .sale-event-banner::before {
      content: '★ ★ ★';
      position: absolute;
      top: 5px;
      left: 15px;
      color: #c5a880;
      font-size: 14px;
      opacity: 0.3;
    }
    .sale-event-banner::after {
      content: '★ ★ ★';
      position: absolute;
      bottom: 5px;
      right: 15px;
      color: #c5a880;
      font-size: 14px;
      opacity: 0.3;
    }
    .sale-title {
      font-family: 'Cinzel', serif;
      font-size: 20px;
      letter-spacing: 2px;
      font-weight: 500;
      margin-bottom: 5px;
      color: #fff;
      text-transform: uppercase;
    }
    .sale-subtitle {
      font-size: 12px;
      letter-spacing: 1px;
      color: #c5a880;
    }

    /* Collection Info Area */
    .collection-header-info {
      text-align: center;
      margin-bottom: 40px;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }
    .collection-main-title {
      font-family: 'Cinzel', serif;
      font-size: 32px;
      letter-spacing: 2px;
      font-weight: 400;
      margin-bottom: 12px;
      text-transform: uppercase;
      color: #111;
    }
    .collection-main-desc {
      font-size: 12px;
      line-height: 1.6;
      color: #555;
    }
    .collection-readmore {
      background: none;
      border: none;
      font-size: 11px;
      color: #c5a880;
      text-decoration: underline;
      font-weight: 600;
      cursor: pointer;
      margin-left: 5px;
    }

    /* Subcategories Grid */
    .subcategories-grid {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      gap: 15px;
      margin-bottom: 45px;
    }
    @media (max-width: 991px) {
      .subcategories-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }
    }
    @media (max-width: 575px) {
      .subcategories-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }
    }
    .subcategory-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      text-decoration: none;
      color: #111;
    }
    .subcategory-img-wrap {
      width: 100%;
      aspect-ratio: 1/1;
      border-radius: 4px;
      background-color: #faf9f8;
      border: 1px solid #f0efee;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 8px;
      transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .subcategory-card:hover .subcategory-img-wrap {
      transform: translateY(-3px);
      border-color: #c5a880;
    }
    .subcategory-img-wrap img {
      max-width: 85%;
      max-height: 85%;
      object-fit: contain;
    }
    .subcategory-name {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.5px;
      line-height: 1.3;
      height: 30px;
      overflow: hidden;
    }

    /* Filter and Sort Bar */
    .filter-sort-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 0;
      border-top: 1px solid #eaeaea;
      border-bottom: 1px solid #eaeaea;
      margin-bottom: 35px;
      flex-wrap: wrap;
      gap: 15px;
    }
    .filter-left {
      display: flex;
      align-items: center;
      gap: 15px;
      flex-wrap: wrap;
    }
    .filter-btn-main {
      background-color: #000;
      color: #fff;
      border: none;
      padding: 10px 18px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      text-transform: uppercase;
    }
    .filter-btn-main i {
      font-size: 13px;
    }
    .filter-dropdown {
      position: relative;
    }
    .filter-dropdown-btn {
      background: none;
      border: 1px solid #ddd;
      padding: 8px 15px;
      font-size: 11px;
      color: #333;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .filter-dropdown-btn:hover {
      border-color: #000;
    }
    
    .filter-right {
      display: flex;
      align-items: center;
      gap: 15px;
    }
    /* Toggle switch style */
    .toggle-container {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }
    .toggle-label {
      font-size: 11px;
      font-weight: 600;
      color: #333;
    }
    .switch {
      position: relative;
      display: inline-block;
      width: 40px;
      height: 22px;
    }
    .switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }
    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #ccc;
      transition: .4s;
      border-radius: 34px;
    }
    .slider::before {
      position: absolute;
      content: "";
      height: 16px;
      width: 16px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: .4s;
      border-radius: 50%;
    }
    input:checked + .slider {
      background-color: #c5a880; /* Gold check color */
    }
    input:checked + .slider::before {
      transform: translateX(18px);
    }

    /* Product List Grid */
    .grid-products-angara {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }
    @media (max-width: 991px) {
      .grid-products-angara {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (max-width: 575px) {
      .grid-products-angara {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
    }

    /* Product Card with Dual Image Hover Fade Effect */
    .product-card-angara {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      position: relative;
    }
    .product-image-container {
      position: relative;
      aspect-ratio: 1/1;
      background-color: #faf9f8;
      border: 1px solid #f3f3f3;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .product-image-container a {
      display: block;
      width: 100%;
      height: 100%;
      position: relative;
    }
    .product-image-container img.img-primary {
      max-width: 85%;
      max-height: 85%;
      object-fit: contain;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      transition: opacity 0.4s ease, transform 0.4s ease;
      opacity: 1;
      z-index: 1;
    }
    .product-image-container img.img-hover {
      max-width: 85%;
      max-height: 85%;
      object-fit: contain;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      transition: opacity 0.4s ease, transform 0.4s ease;
      opacity: 0;
      z-index: 2;
    }
    /* Show secondary hover image on hover */
    .product-card-angara:hover .img-primary {
      opacity: 0;
    }
    .product-card-angara:hover .img-hover {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.04);
    }
    
    .product-quality-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      background-color: rgba(255, 255, 255, 0.9);
      border: 1px solid #ddd;
      color: #666;
      font-size: 8px;
      font-weight: 600;
      padding: 3px 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      z-index: 10;
    }
    .product-wishlist-heart {
      position: absolute;
      top: 10px;
      right: 10px;
      background: none;
      border: none;
      color: #888;
      font-size: 16px;
      z-index: 10;
      transition: color 0.3s ease;
      cursor: pointer;
    }
    .product-wishlist-heart:hover,
    .product-wishlist-heart.active {
      color: #cc0000;
    }
    .product-details-wrap {
      padding: 12px 5px;
      text-align: center;
    }
    .product-brand-name {
      font-size: 9px;
      text-transform: uppercase;
      color: #888;
      letter-spacing: 1px;
      display: block;
      margin-bottom: 4px;
    }
    .product-title-text {
      font-size: 12px;
      font-weight: 500;
      color: #111;
      line-height: 1.5;
      height: 36px;
      overflow: hidden;
      display: block;
      margin-bottom: 6px;
    }
    .product-price-info {
      font-size: 13px;
      font-weight: 600;
      color: #000;
      display: flex;
      justify-content: center;
      gap: 8px;
    }
    .product-compare-price {
      font-size: 12px;
      text-decoration: line-through;
      color: #888;
      font-weight: 400;
    }

    /* Load more / Pagination */
    .load-more-container {
      text-align: center;
      margin: 30px 0 50px 0;
    }
    .btn-black {
      background-color: #000;
      color: #fff;
      border: 1px solid #000;
      padding: 12px 35px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      cursor: pointer;
      text-transform: uppercase;
      transition: all 0.3s ease;
    }
    .btn-black:hover {
      background-color: #fff;
      color: #000;
    }
  </style>

  <div class="angara-collection">
    <!-- BREADCRUMBS -->
    <div class="collection-breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/collections/all">Jewelry</a>
      <span>/</span>
      <span style="color: #111;">{{ collection.title | default: 'Rings' }}</span>
    </div>

    <!-- SALE EVENT BANNER -->
    <section class="sale-event-banner">
      <h2 class="sale-title">4TH OF JULY SALE | 10% OFF SITEWIDE</h2>
      <p class="sale-subtitle">Coupon code auto applied at checkout</p>
    </section>

    <!-- COLLECTION HEADER & INFO -->
    <header class="collection-header-info">
      <h1 class="collection-main-title">{{ collection.title | default: 'Rings' }} <span style="font-size: 16px; color: #888; font-weight: 400;">({{ collection.all_products_count | default: 2477 }})</span></h1>
      <p class="collection-main-desc">
        {% if collection.description != blank %}
          {{ collection.description }}
        {% else %}
          Angara's rings bring together handcrafted designs across gemstones and diamonds, including solitaire, halo, three-stone and contemporary styles set in gold and platinum. Customize gemstone quality, carat... <button class="collection-readmore">Read More</button>
        {% endif %}
      </p>
    </header>

    <!-- SUB-CATEGORIES LIST -->
    <section class="subcategories-grid">
      <a href="/collections/colored-gems" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'product-1.png' | asset_url }}" alt="Colored Gems">
        </div>
        <span class="subcategory-name">Colored Gems</span>
      </a>
      <a href="/collections/diamond" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'product-2.png' | asset_url }}" alt="Diamond">
        </div>
        <span class="subcategory-name">Diamond</span>
      </a>
      <a href="/collections/infinity" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'product-3.png' | asset_url }}" alt="Infinity">
        </div>
        <span class="subcategory-name">Infinity</span>
      </a>
      <a href="/collections/side-stones" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'hero.png' | asset_url }}" alt="Side Stones">
        </div>
        <span class="subcategory-name">Side Stones</span>
      </a>
      <a href="/collections/classic" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'product-1.png' | asset_url }}" alt="Classic">
        </div>
        <span class="subcategory-name">Classic</span>
      </a>
      <a href="/collections/lab-grown" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'product-2.png' | asset_url }}" alt="Lab-Grown">
        </div>
        <span class="subcategory-name">Lab-Grown</span>
      </a>
      <a href="/collections/gia-certified" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'product-3.png' | asset_url }}" alt="GIA Certified">
        </div>
        <span class="subcategory-name">GIA Certified</span>
      </a>
      <a href="/collections/mens-rings" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'hero.png' | asset_url }}" alt="Men's Rings">
        </div>
        <span class="subcategory-name">Men's Rings</span>
      </a>
    </section>

    <!-- FILTER & SORT BAR -->
    <section class="filter-sort-bar">
      <div class="filter-left">
        <button class="filter-btn-main">
          <i class="fa-solid fa-sliders"></i>
          <span>Filter & Sort</span>
        </button>

        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Metal Type <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Natural Gemstones <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Lab Grown Gemstones <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Gemstone Shape <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Jewelry Styles <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Price <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
      </div>

      <div class="filter-right">
        <div class="toggle-container" id="lab-grown-toggle">
          <span class="toggle-label">Lab Grown Only</span>
          <label class="switch">
            <input type="checkbox" id="labgrown-checkbox">
            <span class="slider"></span>
          </label>
        </div>
      </div>
    </section>

    <!-- DYNAMIC PRODUCTS GRID WITH PAGINATION -->
    {% paginate collection.products by 16 %}
      <section class="grid-products-angara">
        {% for product in collection.products %}
          <div class="product-card-angara">
            <div class="product-image-container">
              {%- assign badge_text = "" -%}
              {%- for tag in product.tags -%}
                {%- assign tag_lc = tag | downcase -%}
                {%- if tag_lc contains 'lab-grown' or tag_lc contains 'lab grown' -%}
                  {%- assign badge_text = "LAB GROWN" -%}
                  {%- break -%}
                {%- elsif tag_lc contains 'best' or tag_lc contains 'hot' -%}
                  {%- assign badge_text = "BEST SELLER" -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if badge_text != "" -%}
                <span class="product-quality-badge">{{ badge_text }}</span>
              {%- endif -%}
              
              <button type="button" class="product-wishlist-heart" title="Add to Wishlist" data-id="{{ product.id }}">
                <i class="fa-regular fa-heart"></i>
              </button>
              
              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '600x' }}" class="img-primary" alt="{{ product.title | escape }}">
                  {% if product.images[1] %}
                    <img src="{{ product.images[1] | img_url: '600x' }}" class="img-hover" alt="{{ product.title | escape }}">
                  {% endif %}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'img-primary' }}
                {% endif %}
              </a>
            </div>

            <a href="{{ product.url }}" class="product-details-wrap">
              <span class="product-brand-name">{{ product.vendor | default: shop.name }}</span>
              <span class="product-title-text">{{ product.title }}</span>
              <div class="product-price-info">
                {% if product.compare_at_price > product.price %}
                  <span class="product-compare-price">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                  <span style="color:#e8000d;">{{ product.price | money_without_trailing_zeros }}</span>
                {% else %}
                  <span>{{ product.price | money_without_trailing_zeros }}</span>
                {% endif %}
              </div>
            </a>
          </div>
        {% else %}
          {%- comment -%} Render mock products if the collection has no products {%- endcomment -%}
          {% for i in (1..8) %}
            <div class="product-card-angara">
              <div class="product-image-container">
                <span class="product-quality-badge">LAB GROWN</span>
                
                <button type="button" class="product-wishlist-heart" title="Add to Wishlist">
                  <i class="fa-regular fa-heart"></i>
                </button>
                
                <a href="/products/mock-ring-{{ i }}">
                  {% capture index %}{% cycle '1', '2', '3', '1', '2', '3', '1', '2' %}{% endcapture %}
                  <img src="{{ 'product-' | append: index | append: '.png' | asset_url }}" class="img-primary" alt="Mock Ring {{ i }}">
                  <img src="{{ 'product-' | append: index | append: '.png' | asset_url }}" class="img-hover" alt="Mock Ring {{ i }}">
                </a>
              </div>

              <a href="/products/mock-ring-{{ i }}" class="product-details-wrap">
                <span class="product-brand-name">ARLENA</span>
                <span class="product-title-text">Classic Round Lab-Grown Diamond Solitaire Ring</span>
                <div class="product-price-info">
                  <span class="product-compare-price">$2,669</span>
                  <span style="color:#e8000d;">$2,402</span>
                </div>
              </a>
            </div>
          {% endfor %}
        {% endfor %}
      </section>

      {% if paginate.pages > 1 %}
        <div class="load-more-container">
          <div class="pagination">
            {{ paginate | default_pagination }}
          </div>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    /* Wishlist toggling in collection */
    var heartBtns = document.querySelectorAll('.product-wishlist-heart');
    heartBtns.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.classList.toggle('active');
        var icon = this.querySelector('i');
        if(this.classList.contains('active')) {
          icon.className = 'fa-solid fa-heart';
          icon.style.color = '#cc0000';
        } else {
          icon.className = 'fa-regular fa-heart';
          icon.style.color = '';
        }
      });
    });

    /* Lab Grown toggle event */
    var checkbox = document.getElementById('labgrown-checkbox');
    if (checkbox) {
      checkbox.addEventListener('change', function() {
        // Mock filtering effect
        var cards = document.querySelectorAll('.product-card-angara');
        cards.forEach(function(card) {
          if (checkbox.checked) {
            // Randomly show/hide some for effect, or filter by lab grown handles
            var isLabGrown = Math.random() > 0.3;
            card.style.opacity = isLabGrown ? '1' : '0.2';
          } else {
            card.style.opacity = '1';
          }
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Main Collection",
  "settings": [],
  "presets": [
    {
      "name": "Main Collection"
    }
  ]
}
{% endschema %}
