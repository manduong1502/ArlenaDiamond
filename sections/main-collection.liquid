<main class="main-collection full-width">
  <style>
    /* Arlena-style Collection Page Styles */
    .arlena-collection {
      max-width: 1500px; /* Expanded from 1200px to reduce blank sides */
      margin: 0 auto 40px auto; /* Removed top margin, handled by container or post-banner */
      padding: 0 40px;
      font-family: var(--font-base);
      color: #111;
      box-sizing: border-box;
    }
    .collection-breadcrumbs-container {
      max-width: 1500px;
      margin: 140px auto 12px auto; /* Comfortable clearance for fixed header, tight bottom margin */
      padding: 0 40px;
      box-sizing: border-box;
    }
    .arlena-collection.post-banner {
      margin-top: 25px; /* Tighter gap after banner */
    }
    @media (max-width: 991px) {
      .arlena-collection {
        padding: 0 20px;
      }
      .collection-breadcrumbs-container {
        margin: 110px auto 10px auto;
        padding: 0 20px;
      }
      .arlena-collection.post-banner {
        margin-top: 20px;
      }
    }

    /* Breadcrumbs */
    .collection-breadcrumbs {
      font-size: 10px;
      color: #777;
      letter-spacing: 1px;
      margin: 0; /* Cleared margin to allow container control */
      text-transform: uppercase;
      font-weight: 500;
    }
    .collection-breadcrumbs a {
      color: #777;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .collection-breadcrumbs a:hover {
      color: #000;
    }
    .collection-breadcrumbs span {
      margin: 0 6px;
      color: #ccc;
    }

    /* Panoramic Sale Event Banner - Full screen width */
    .sale-event-banner {
      width: 100%;
      height: auto;
      margin-bottom: 25px;
      overflow: hidden;
      border-top: 1px solid #eaeaea;
      border-bottom: 1px solid #eaeaea;
    }
    .sale-event-banner img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* Collection Info Area */
    .collection-header-info {
      text-align: center;
      margin-bottom: 40px;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }
    .collection-main-title {
      font-family: 'Cinzel', serif;
      font-size: 32px;
      letter-spacing: 2px;
      font-weight: 400;
      margin-bottom: 12px;
      text-transform: uppercase;
      color: #111;
    }
    .collection-main-desc {
      font-size: 12px;
      line-height: 1.6;
      color: #555;
    }
    .collection-readmore {
      background: none;
      border: none;
      font-size: 11px;
      color: #c5a880;
      text-decoration: underline;
      font-weight: 600;
      cursor: pointer;
      margin-left: 5px;
    }

    /* Subcategories Grid */
    .subcategories-grid {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      gap: 15px;
      margin-bottom: 45px;
    }
    @media (max-width: 991px) {
      .subcategories-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }
    }
    @media (max-width: 575px) {
      .subcategories-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }
    }
    .subcategory-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      text-decoration: none;
      color: #111;
    }
    .subcategory-img-wrap {
      width: 100%;
      aspect-ratio: 1/1;
      border-radius: 4px;
      background-color: #faf9f8;
      border: 1px solid #f0efee;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 8px;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .subcategory-card:hover .subcategory-img-wrap {
      transform: translateY(-3px);
      border-color: #c5a880;
      box-shadow: 0 4px 15px rgba(197, 168, 128, 0.15);
    }
    .subcategory-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .subcategory-name {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.5px;
      line-height: 1.3;
      height: 30px;
      overflow: hidden;
    }

    /* Filter and Sort Bar */
    .filter-sort-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 0;
      border-top: 1px solid #eaeaea;
      border-bottom: 1px solid #eaeaea;
      margin-bottom: 35px;
      flex-wrap: wrap;
      gap: 15px;
    }
    .filter-left {
      display: flex;
      align-items: center;
      gap: 15px;
      flex-wrap: wrap;
    }
    .filter-btn-main {
      background-color: #000;
      color: #fff;
      border: none;
      padding: 9px 20px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      text-transform: uppercase;
      border-radius: 20px;
      transition: background-color 0.2s ease;
    }
    .filter-btn-main:hover {
      background-color: #333;
    }
    .filter-btn-main i {
      font-size: 12px;
    }
    .filter-dropdown {
      position: relative;
    }
    .filter-dropdown-btn {
      background: none;
      border: 1px solid #ddd;
      padding: 8px 18px;
      font-size: 11px;
      color: #333;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      border-radius: 20px;
      transition: all 0.2s ease;
    }
    .filter-dropdown-btn:hover {
      border-color: #000;
      color: #000;
    }
    
    .filter-right {
      display: flex;
      align-items: center;
      gap: 15px;
    }
    /* Toggle switch style */
    .toggle-container {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }
    .toggle-label {
      font-size: 11px;
      font-weight: 600;
      color: #333;
    }
    .switch {
      position: relative;
      display: inline-block;
      width: 40px;
      height: 22px;
    }
    .switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }
    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #ccc;
      transition: .4s;
      border-radius: 34px;
    }
    .slider::before {
      position: absolute;
      content: "";
      height: 16px;
      width: 16px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: .4s;
      border-radius: 50%;
    }
    input:checked + .slider {
      background-color: #c5a880; /* Gold check color */
    }
    input:checked + .slider::before {
      transform: translateX(18px);
    }

    /* Product List Grid */
    .grid-products-arlena {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }
    @media (max-width: 991px) {
      .grid-products-arlena {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (max-width: 575px) {
      .grid-products-arlena {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
    }

    /* Product Card with Dual Image Hover Fade Effect */
    .product-card-arlena {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      position: relative;
    }
    .product-image-container {
      position: relative;
      aspect-ratio: 1/1;
      background-color: #fafaf9; /* soft luxury off-white background */
      border: none; /* Removed borders around container to blend smoothly */
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .product-image-container a {
      display: block;
      width: 100%;
      height: 100%;
      position: relative;
    }
    .product-image-container img.img-primary {
      width: 100%;
      height: 100%;
      object-fit: cover; /* Cover edge-to-edge full width & height */
      position: absolute;
      top: 0;
      left: 0;
      transition: opacity 0.4s ease, transform 0.4s ease;
      opacity: 1;
      z-index: 1;
    }
    .product-image-container img.img-hover {
      width: 100%;
      height: 100%;
      object-fit: cover; /* Cover edge-to-edge full width & height */
      position: absolute;
      top: 0;
      left: 0;
      transition: opacity 0.4s ease, transform 0.4s ease;
      opacity: 0;
      z-index: 2;
    }
    /* Show secondary hover image on hover */
    .product-card-arlena:hover .img-primary {
      opacity: 0;
    }
    .product-card-arlena:hover .img-hover {
      opacity: 1;
      transform: scale(1.04); /* Slight premium scale centered */
    }
    
    .product-quality-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background-color: #111;
      color: #fff;
      font-size: 8px;
      font-weight: 600;
      padding: 4px 8px;
      text-transform: uppercase;
      letter-spacing: 1px;
      z-index: 10;
      border-radius: 2px;
    }

    /* Product Details - Left Aligned to match Mockup (Image 4) */
    .product-details-wrap {
      padding: 12px 0;
      text-align: left;
    }
    
    /* Gemstone Swatches matching Example Card */
    .product-swatches {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 6px;
      margin-bottom: 8px;
    }
    .swatch-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 1px solid #ddd;
      padding: 1px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: border-color 0.2s ease;
    }
    .swatch-dot:hover {
      border-color: #999;
    }
    .swatch-dot.active {
      border-color: #111;
    }
    .swatch-dot-inner {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      display: block;
    }

    .product-title-text {
      font-size: 13px;
      font-weight: 400;
      color: #111;
      line-height: 1.5;
      height: 39px;
      overflow: hidden;
      display: block;
      margin-bottom: 8px;
      margin-top: 4px;
      transition: color 0.3s ease;
    }
    .product-card-arlena:hover .product-title-text {
      color: #c5a880;
    }
    .product-price-info {
      font-size: 14px;
      font-weight: 700;
      color: #111;
      display: flex;
      justify-content: flex-start;
      gap: 8px;
    }

    .product-compare-price {
      font-size: 12px;
      text-decoration: line-through;
      color: #888;
      font-weight: 400;
    }

    /* Load more / Pagination */
    .load-more-container {
      text-align: center;
      margin: 30px 0 50px 0;
    }
    .btn-black {
      background-color: #000;
      color: #fff;
      border: 1px solid #000;
      padding: 12px 35px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      cursor: pointer;
      text-transform: uppercase;
      transition: all 0.3s ease;
    }
    .btn-black:hover {
      background-color: #fff;
      color: #000;
    }
  </style>

  {%- assign current_handle = collection.handle | downcase -%}

  {%- assign page_title = collection.title -%}
  {%- if page_title == blank or page_title == 'Products' or page_title == 'All' or page_title == 'Rings' -%}
    {%- if current_handle contains 'engagement' -%}
      {%- assign page_title = "Engagement Rings" -%}
    {%- elsif current_handle contains 'wedding' -%}
      {%- assign page_title = "Wedding Bands" -%}
    {%- elsif current_handle contains 'earring' -%}
      {%- assign page_title = "Earrings" -%}
    {%- elsif current_handle contains 'pendant' or current_handle contains 'necklace' -%}
      {%- assign page_title = "Pendants" -%}
    {%- elsif current_handle contains 'bracelet' -%}
      {%- assign page_title = "Bracelets" -%}
    {%- elsif current_handle contains 'gift' -%}
      {%- assign page_title = "Gifts" -%}
    {%- else -%}
      {%- assign page_title = "All Jewellery" -%}
    {%- endif -%}
  {%- endif -%}

  {%- assign page_desc = collection.description -%}
  {%- if page_desc == blank -%}
    {%- if current_handle contains 'engagement' -%}
      {%- assign page_desc = "Explore Arlena's collection of handcrafted Engagement Rings. Designed and crafted in Australia with ethically sourced diamonds and precious gold or platinum." -%}
    {%- elsif current_handle contains 'wedding' -%}
      {%- assign page_desc = "Discover Arlena's Wedding Bands, crafted to order in Australia. Designed to complement your engagement ring or shine beautifully on their own." -%}
    {%- elsif current_handle contains 'earring' -%}
      {%- assign page_desc = "Explore Arlena's fine diamond Earrings, from timeless solitaire studs to exquisite halo drop designs crafted in Australia." -%}
    {%- elsif current_handle contains 'pendant' or current_handle contains 'necklace' -%}
      {%- assign page_desc = "Discover Arlena's solitaire and halo Diamond Pendants, thoughtfully designed and handcrafted in Australia to celebrate life's special moments." -%}
    {%- elsif current_handle contains 'bracelet' -%}
      {%- assign page_desc = "Explore Arlena's collection of diamond Tennis Bracelets, handcrafted in Australia in yellow gold, white gold, rose gold and platinum." -%}
    {%- else -%}
      {%- assign page_desc = "Arlena's fine jewellery brings together handcrafted designs across gemstones and diamonds, including solitaire, halo, three-stone and contemporary styles set in gold and platinum." -%}
    {%- endif -%}
  {%- endif -%}

  <!-- 1. BREADCRUMBS BLOCK -->
  <div class="collection-breadcrumbs-container">
    <div class="collection-breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      {% if current_handle != 'all' and current_handle != blank %}
        <a href="/collections/all">Collections</a>
        <span>/</span>
        <span style="color: #111;">{{ page_title }}</span>
      {% else %}
        <span style="color: #111;">All Jewellery</span>
      {% endif %}
    </div>
  </div>

  <!-- 2. PANORAMIC SALE EVENT BANNER -->
  <section class="sale-event-banner">
    <img src="{{ 'collection_banner.webp' | asset_url }}" alt="Arlena Fine Jewellery">
  </section>

  <!-- 3. MAIN CONTENT CONTAINER -->
  <div class="arlena-collection post-banner">
    <!-- COLLECTION HEADER & INFO -->
    <header class="collection-header-info">
      <h1 class="collection-main-title">{{ page_title }}</h1>
      <p class="collection-main-desc">{{ page_desc }}</p>
    </header>

    <!-- SUB-CATEGORIES LIST -->
    <section class="subcategories-grid">
      <a href="/collections/engagement-rings" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'cat_engagement.png' | asset_url }}" alt="Engagement Rings">
        </div>
        <span class="subcategory-name">Engagement Rings</span>
      </a>
      <a href="/collections/wedding-bands" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'cat_wedding.png' | asset_url }}" alt="Wedding Bands">
        </div>
        <span class="subcategory-name">Wedding Bands</span>
      </a>
      <a href="/collections/earrings" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'cat_earrings.png' | asset_url }}" alt="Earrings">
        </div>
        <span class="subcategory-name">Earrings</span>
      </a>
      <a href="/collections/pendants" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'cat_pendants.png' | asset_url }}" alt="Pendants">
        </div>
        <span class="subcategory-name">Pendants</span>
      </a>
      <a href="/collections/bracelets" class="subcategory-card">
        <div class="subcategory-img-wrap">
          <img src="{{ 'cat_bracelets.png' | asset_url }}" alt="Bracelets">
        </div>
        <span class="subcategory-name">Bracelets</span>
      </a>
    </section>

    <!-- FILTER & SORT BAR -->
    <section class="filter-sort-bar">
      <div class="filter-left">
        <button class="filter-btn-main">
          <i class="fa-solid fa-sliders"></i>
          <span>Filter & Sort</span>
        </button>

        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Metal Type <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Natural Gemstones <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Lab Grown Gemstones <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Gemstone Shape <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Jewelry Styles <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
        <div class="filter-dropdown">
          <button class="filter-dropdown-btn">Price <i class="fa-solid fa-chevron-down" style="font-size:8px;"></i></button>
        </div>
      </div>

      <div class="filter-right">
        <div class="toggle-container" id="lab-grown-toggle">
          <span class="toggle-label">Lab Grown Only</span>
          <label class="switch">
            <input type="checkbox" id="labgrown-checkbox">
            <span class="slider"></span>
          </label>
        </div>
      </div>
    </section>

    <!-- DYNAMIC PRODUCTS GRID WITH PAGINATION & SMART FILTER -->
    {% paginate collections.all.products by 48 %}
      <section class="grid-products-arlena">
        {% for product in collections.all.products %}
          {%- assign show_prod = false -%}
          {%- assign p_type_lc = product.type | downcase -%}
          {%- assign p_handle_lc = product.handle | downcase -%}
          {%- assign p_tags_lc = product.tags | join: ',' | downcase -%}

          {%- if current_handle contains 'engagement' -%}
            {%- if p_type_lc contains 'engagement' or p_handle_lc contains 'engagement' or p_tags_lc contains 'engagement' or p_type_lc == 'ring' or p_type_lc == 'rings' -%}
              {%- unless p_handle_lc contains 'wedding' or p_type_lc contains 'wedding' -%}
                {%- assign show_prod = true -%}
              {%- endunless -%}
            {%- endif -%}
          {%- elsif current_handle contains 'wedding' -%}
            {%- if p_type_lc contains 'wedding' or p_handle_lc contains 'wedding' or p_tags_lc contains 'wedding' or p_handle_lc contains 'band' -%}
              {%- assign show_prod = true -%}
            {%- endif -%}
          {%- elsif current_handle contains 'earring' -%}
            {%- if p_type_lc contains 'earring' or p_handle_lc contains 'earring' or p_tags_lc contains 'earring' -%}
              {%- assign show_prod = true -%}
            {%- endif -%}
          {%- elsif current_handle contains 'pendant' or current_handle contains 'necklace' -%}
            {%- if p_type_lc contains 'pendant' or p_type_lc contains 'necklace' or p_handle_lc contains 'pendant' or p_handle_lc contains 'necklace' or p_tags_lc contains 'pendant' -%}
              {%- assign show_prod = true -%}
            {%- endif -%}
          {%- elsif current_handle contains 'bracelet' -%}
            {%- if p_type_lc contains 'bracelet' or p_handle_lc contains 'bracelet' or p_tags_lc contains 'bracelet' -%}
              {%- assign show_prod = true -%}
            {%- endif -%}
          {%- elsif current_handle == 'all' or current_handle == blank -%}
            {%- assign show_prod = true -%}
          {%- else -%}
            {%- assign show_prod = true -%}
          {%- endif -%}

          {%- if show_prod -%}
            <div class="product-card-arlena">
            <div class="product-image-container">
              {%- assign badge_text = "" -%}
              {%- for tag in product.tags -%}
                {%- assign tag_lc = tag | downcase -%}
                {%- if tag_lc contains 'lab-grown' or tag_lc contains 'lab grown' -%}
                  {%- assign badge_text = "LAB GROWN" -%}
                  {%- break -%}
                {%- elsif tag_lc contains 'best' or tag_lc contains 'hot' -%}
                  {%- assign badge_text = "BEST SELLER" -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if badge_text != "" -%}
                <span class="product-quality-badge">{{ badge_text }}</span>
              {%- endif -%}
              

              
              <a href="{{ product.url }}">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '600x' }}" class="img-primary" alt="{{ product.title | escape }}">
                  {% if product.images[1] %}
                    <img src="{{ product.images[1] | img_url: '600x' }}" class="img-hover" alt="{{ product.title | escape }}">
                  {% endif %}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'img-primary' }}
                {% endif %}
              </a>
            </div>

            <a href="{{ product.url }}" class="product-details-wrap">
              <!-- Swatches row matching mockup Image 4 -->
              {%- assign stone_option = nil -%}
              {%- for option in product.options_with_values -%}
                {%- assign opt_name = option.name | downcase -%}
                {%- if opt_name == 'color' or opt_name == 'stone' or opt_name == 'gemstone' or opt_name == 'metal' -%}
                  {%- assign stone_option = option -%}
                  {%- assign stone_opt_index = forloop.index0 -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}

              <div class="product-swatches">
                {%- if stone_option -%}
                  {%- assign seen_colors = "" -%}
                  {%- for value in stone_option.values -%}
                    {%- assign val_lc = value | downcase -%}
                    {%- assign color_key = "" -%}
                    {%- if val_lc contains 'yellow' -%}{%- assign color_key = "yellow" -%}
                    {%- elsif val_lc contains 'rose' -%}{%- assign color_key = "rose" -%}
                    {%- elsif val_lc contains 'white' -%}{%- assign color_key = "white" -%}
                    {%- elsif val_lc contains 'platinum' -%}{%- assign color_key = "platinum" -%}
                    {%- endif -%}
                    
                    {%- if color_key != "" -%}
                      {%- unless seen_colors contains color_key -%}
                        {%- assign seen_colors = seen_colors | append: color_key | append: "," -%}
                      {%- endunless -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- assign unique_colors = seen_colors | split: "," -%}

                  {%- for color in unique_colors -%}
                    {%- assign swatch_bg = '#ccc' -%}
                    {%- if color == 'yellow' -%}{%- assign swatch_bg = '#e5d0a4' -%}{%- assign color_name = 'Yellow Gold' -%}
                    {%- elsif color == 'rose' -%}{%- assign swatch_bg = '#e0b39f' -%}{%- assign color_name = 'Rose Gold' -%}
                    {%- elsif color == 'white' -%}{%- assign swatch_bg = '#e2e2e2' -%}{%- assign color_name = 'White Gold' -%}
                    {%- elsif color == 'platinum' -%}{%- assign swatch_bg = '#dfdfdf' -%}{%- assign color_name = 'Platinum' -%}
                    {%- endif -%}

                    {%- assign matched_img_url = nil -%}
                    {%- for img in product.images -%}
                      {%- assign img_alt_lc = img.alt | downcase -%}
                      {%- if img_alt_lc contains color -%}
                        {%- assign matched_img_url = img | img_url: '600x' -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- unless matched_img_url -%}
                      {%- assign matched_img_url = product.featured_image | img_url: '600x' -%}
                    {%- endunless -%}

                    <div class="swatch-dot {% if forloop.first %}active{% endif %}" title="{{ color_name }}" data-color-img="{{ matched_img_url }}">
                      <span class="swatch-dot-inner" style="background-color: {{ swatch_bg }};"></span>
                    </div>
                  {%- endfor -%}
                {%- else -%}
                  <!-- Mock swatches for showcase consistency -->
                  <div class="swatch-dot active" title="Yellow Gold" data-color-img="">
                    <span class="swatch-dot-inner" style="background-color: #e5d0a4;"></span>
                  </div>
                  <div class="swatch-dot" title="Rose Gold" data-color-img="">
                    <span class="swatch-dot-inner" style="background-color: #e0b39f;"></span>
                  </div>
                  <div class="swatch-dot" title="White Gold" data-color-img="">
                    <span class="swatch-dot-inner" style="background-color: #e2e2e2;"></span>
                  </div>
                  <div class="swatch-dot" title="Platinum" data-color-img="">
                    <span class="swatch-dot-inner" style="background-color: #dfdfdf;"></span>
                  </div>
                {%- endif -%}
              </div>

              <span class="product-title-text">{{ product.title }}</span>
              
              <div class="product-price-info">
                {% if product.compare_at_price > product.price %}
                  <span class="product-compare-price">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                  <span style="color:#e8000d;">{{ product.price | money_without_trailing_zeros }}</span>
                {% else %}
                  <span>{{ product.price | money_without_trailing_zeros }}</span>
                {% endif %}
            </a>
          </div>
        {%- endif -%}
      {% endfor %}
    </section>

      {% if paginate.pages > 1 %}
        <div class="load-more-container">
          <div class="pagination">
            {{ paginate | default_pagination }}
          </div>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    /* Wishlist toggling in collection */
    var heartBtns = document.querySelectorAll('.product-wishlist-heart');
    heartBtns.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        this.classList.toggle('active');
        var icon = this.querySelector('i');
        if(this.classList.contains('active')) {
          icon.className = 'fa-solid fa-heart';
          icon.style.color = '#cc0000';
        } else {
          icon.className = 'fa-regular fa-heart';
          icon.style.color = '';
        }
      });
    });

    /* Swatch image switching in collection */
    var swatchDots = document.querySelectorAll('.product-swatches .swatch-dot');
    swatchDots.forEach(function(dot) {
      dot.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        var card = this.closest('.product-card-arlena');
        if (!card) return;
        
        // Update active class on sibling swatches
        var siblings = card.querySelectorAll('.product-swatches .swatch-dot');
        siblings.forEach(function(s) { s.classList.remove('active'); });
        this.classList.add('active');
        
        // Update product card image sources
        var newImgUrl = this.getAttribute('data-color-img');
        if (newImgUrl) {
          var primaryImg = card.querySelector('.img-primary');
          var hoverImg = card.querySelector('.img-hover');
          if (primaryImg) {
            primaryImg.src = newImgUrl;
          }
          if (hoverImg) {
            hoverImg.src = newImgUrl;
          }
        }
      });
    });

    /* Lab Grown toggle event */
    var checkbox = document.getElementById('labgrown-checkbox');
    if (checkbox) {
      checkbox.addEventListener('change', function() {
        // Mock filtering effect
        var cards = document.querySelectorAll('.product-card-arlena');
        cards.forEach(function(card) {
          if (checkbox.checked) {
            // Randomly show/hide some for effect, or filter by lab grown handles
            var isLabGrown = Math.random() > 0.3;
            card.style.opacity = isLabGrown ? '1' : '0.2';
          } else {
            card.style.opacity = '1';
          }
        });
      });
    }
  });
</script>

