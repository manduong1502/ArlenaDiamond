<main class="main-collection full-width">
  <style>
    /* ─── HEADER AREA ─── */
    .collection-page-header {
      max-width: 100%;
      margin: 80px auto 0 auto;
      padding: 20px 60px 20px 60px;
    }
    .collection-pill {
      border: 1px solid #000;
      border-radius: 20px;
      padding: 7px 18px;
      font-size: 14px;
      text-transform: uppercase;
      color: #000;
      text-decoration: none;
      letter-spacing: 0.5px;
      font-family: var(--font-base);
      transition: all 0.2s ease;
      white-space: nowrap;
      display: inline-block;
    }
    .collection-pill:hover {
      background-color: #000;
      color: #fff;
    }

    /* ─── GRID ─── */
    .main-collection {
      background: #fff;
    }
    .collection-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      padding: 0 60px;
      margin-bottom: 60px;
      background: #fff;
    }
    @media (max-width: 1024px) {
      .collection-grid {
        grid-template-columns: repeat(3, 1fr);
        padding: 0 40px;
      }
    }

    /* ─── CARD ─── */
    .grid-item {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      position: relative;
      border-radius: 4px;
      box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
      overflow: hidden;
      background: #fff;
    }
    .image-wrapper {
      position: relative;
      overflow: hidden;
      aspect-ratio: 3/4;
      background: transparent;
      display: block;
    }
    .image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: opacity 0.3s ease;
    }
    .img-secondary {
      position: absolute;
      top: 0;
      left: 0;
      opacity: 0;
    }
    .grid-item:hover .img-primary {
      opacity: 0;
    }
    .grid-item:hover .img-secondary {
      opacity: 1;
    }
    .bookmark-icon {
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 10;
      cursor: pointer;
      color: #111;
    }

    /* ─── SIZE OVERLAY ─── */
    .size-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.92);
      padding: 10px 8px;
      text-align: center;
      transform: translateY(100%);
      transition: transform 0.25s ease, opacity 0.25s ease;
      opacity: 0;
      z-index: 10;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 8px;
    }
    .grid-item:hover .size-overlay {
      transform: translateY(0);
      opacity: 1;
    }
    .size-overlay span {
      font-size: 14px;
      font-family: var(--font-base);
    }
    .size-avail {
      color: #111;
      font-weight: 700;
      cursor: pointer;
    }
    .size-avail:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .size-unavail {
      color: #bbb;
      font-weight: 400;
      pointer-events: none;
    }

    /* ─── CARD INFO ─── */
    .item-info {
      display: flex;
      flex-direction: column;
      gap: 3px;
      background: #fff;
      padding: 10px;
    }
    .item-vendor {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      color: #5d5c5c;
      letter-spacing: 0.8px;
    }
    .item-title {
      font-size: 14px;
      font-weight: 400;
      color: #111;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .item-price {
      font-size: 12px;
      font-weight: 600;
      color: #111;
      display: flex;
      gap: 8px;
      margin-top: 3px;
    }
    .price-compare {
      text-decoration: line-through;
      color: #aaa;
      font-weight: 400;
    }
    .price-sale {
      color: #e8000d;
    }
    .price-regular {
      color: #111;
    }
    .item-swatches {
      display: flex;
      gap: 6px;
      align-items: center;
    }
    .swatch {
      width: 35px;
      height: 35px;
      border-radius: 50%;
      border: 1.5px solid #ddd;
      cursor: pointer;
      transition: border-color 0.2s, transform 0.2s;
      background-size: cover;
      background-position: center;
    }
    .swatch:hover {
      border-color: #000;
      transform: scale(1.08);
    }

    /* ══════════════════════════════════ */
    /* MOBILE  ≤ 768px                    */
    /* ══════════════════════════════════ */
    @media (max-width: 768px) {
      /* Header */
      .collection-page-header {
        margin-top: 70px;
        padding: 16px 16px 12px 16px;
      }
      .collection-main-title {
        font-size: 16px !important;
        font-weight: 600 !important;
        color: #111 !important;
        margin-bottom: 3px !important;
      }
      .collection-breadcrumbs {
        font-size: 11px !important;
        color: #999 !important;
        margin-bottom: 14px !important;
      }

      /* Pills – horizontal scroll */
      .collection-pills {
        display: flex !important;
        flex-wrap: nowrap !important;
        overflow-x: auto !important;
        gap: 8px !important;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 2px;
      }
      .collection-pills::-webkit-scrollbar {
        display: none;
      }
      .collection-pill {
        font-size: 11px !important;
        padding: 5px 14px !important;
        border-radius: 20px;
        white-space: nowrap;
      }

      /* Controls row */
      .collection-controls-row {
        flex-direction: row !important;
        align-items: center !important;
        justify-content: space-between;
        gap: 10px !important;
        border-top: 1px solid #e8e8e8;
        margin-top: 12px;
        padding-top: 10px;
      }
      .product-count {
        font-size: 12px !important;
        color: #999 !important;
        font-weight: 400 !important;
      }
      .collection-actions {
        gap: 14px !important;
        font-size: 12px !important;
      }
      .sort-by,
      .filter-action {
        font-size: 12px !important;
        font-weight: 600 !important;
        color: #111 !important;
      }

      /* Grid */
      .collection-grid {
        grid-template-columns: repeat(2, 1fr) !important;
        padding: 10px 12px 40px !important;
        gap: 12px 8px !important;
      }

      /* Card */
      .image-wrapper {
        margin-bottom: 8px;
      }
      .item-vendor {
        font-size: 8px !important;
        letter-spacing: 0.5px;
      }
      .item-title {
        font-size: 11px !important;
      }
      .item-price {
        font-size: 11px !important;
        margin-top: 2px;
      }
      .swatch {
        width: 28px !important;
        height: 28px !important;
      }
      .bookmark-icon {
        top: 6px;
        left: 6px;
      }
      .size-overlay {
        display: none;
      } /* on mobile no hover, hide size */
    }
  </style>

  <!-- NEW COLLECTION PAGE HEADER -->
  <div class="collection-page-header">
    {% capture display_title %}
      {% if collection.handle == 'women' %}
        {% if current_tags.first == 'top' %}WOMENS TOPS
        {% elsif current_tags.first == 'bottom' %}WOMENS BOTTOMS
        {% elsif current_tags.first == 'dresses' %}WOMENS DRESSES
        {% elsif current_tags.first == 'streetwear' %}WOMENS STREETWEAR
        {% else %}Shop All Womens Clothing{% endif %}
      {% elsif collection.handle == 'men' %}
        {% if current_tags.first == 'top' %}MENS TOPS
        {% elsif current_tags.first == 'bottom' %}MENS BOTTOMS
        {% elsif current_tags.first == 'streetwear' %}MENS STREETWEAR
        {% else %}Shop All Mens Clothing{% endif %}
      {% else %}
        {{ collection.title }}
      {% endif %}
    {% endcapture %}

    <h1
      class="collection-main-title"
      style="font-size: 24px; font-weight: 500; font-family: var(--font-base); margin-bottom: 5px; letter-spacing: 0; color: #1a1a1a;"
    >
      {{ display_title | strip }}
    </h1>

    <div
      class="collection-breadcrumbs"
      style="font-size: 12px; color: #777; margin-bottom: 25px; font-family: var(--font-base);"
    >
      <a href="/" style="color: #777; text-decoration: none;">Home</a>
      {% if current_tags.first %}
        <span style="margin: 0 4px;">/</span>
        <a href="{{ collection.url }}" style="color: #777; text-decoration: none; text-transform: capitalize;">
          {{- collection.title -}}
        </a>
        <span style="margin: 0 4px;">/</span> <span style="color: #777;">Clothing</span>
        <span style="margin: 0 4px;">/</span>
        <span style="color: #777; text-transform: capitalize;">{{ current_tags.first }}</span>
      {% else %}
        <span style="margin: 0 4px;">/</span> <span style="color: #777;">{{ display_title | strip }}</span>
      {% endif %}
    </div>

    <div
      class="collection-controls-row"
      style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; padding-bottom: 5px;"
    >
      <div class="collection-pills" style="display: flex; gap: 10px; flex-wrap: wrap;">
        <!-- Luôn hiển thị Best Seller -->
        <a
          href="{{ collection.url }}?sort_by=best-selling"
          class="collection-pill {% if request.url contains 'sort_by=best-selling' %}active-pill{% endif %}"
          >BEST SELLER</a
        >

        <!-- Tự động load các tag đang có trong Collection -->
        {% for tag in collection.all_tags %}
          {% if tag contains '_' %}{% continue %}{% endif %}
          <!-- Bỏ qua các tag hệ thống bắt đầu bằng dấu gạch dưới -->
          {% assign tag_handle = tag | handleize %}

          {% if current_tags contains tag %}
            <a
              href="{{ collection.url }}"
              class="collection-pill"
              style="background:#000; color:#fff;"
              title="Remove filter"
            >
              {{- tag | upcase }} ✕</a
            >
          {% else %}
            <a href="{{ collection.url }}/{{ tag_handle }}" class="collection-pill">{{ tag | upcase }}</a>
          {% endif %}
        {% endfor %}
      </div>

      <div
        class="collection-actions"
        style="display: flex; align-items: center; gap: 25px; font-size: 14px; font-family: var(--font-base);"
      >
        <span class="product-count" style="color: #333;">
          {{- collection.products_count | default: '1,068' }} products</span
        >
        <span class="sort-by" style="font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 6px;">
          Sort By
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
        <span
          class="filter-action"
          style="font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 8px;"
        >
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
            <path d="M2 4H14M5 8H11M7.5 12H8.5" stroke="black" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          Filter
        </span>
      </div>
    </div>
  </div>

  <!-- PRODUCT GRID -->
  <section class="collection-grid" id="product-grid-container">
    {% for product in collection.products %}
      {%- comment -%} --- Detect color option --- {%- endcomment -%}
      {%- assign col_opt = null -%}
      {%- for opt in product.options_with_values -%}
        {%- assign opt_lc = opt.name | downcase -%}
        {%- if opt_lc == 'color' or opt_lc == 'colour' -%}
          {%- assign col_opt = opt -%}
          {%- assign col_opt_pos = opt.position -%}
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Build unique color list {%- endcomment -%}
      {%- assign unique_colors = '' -%}
      {%- if col_opt -%}
        {%- for variant in product.variants -%}
          {%- if col_opt_pos == 1 -%}{%- assign vcol = variant.option1 -%}{%- endif -%}
          {%- if col_opt_pos == 2 -%}{%- assign vcol = variant.option2 -%}{%- endif -%}
          {%- if col_opt_pos == 3 -%}{%- assign vcol = variant.option3 -%}{%- endif -%}
          {%- unless unique_colors contains vcol -%}
            {%- assign unique_colors = unique_colors | append: vcol | append: '||' -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
      {%- assign unique_color_arr = unique_colors | split: '||' -%}

      {%- comment -%} If no color option or only 1 color → normal single card logic {%- endcomment -%}
      {%- assign render_colors = unique_color_arr -%}
      {%- if col_opt == null or unique_color_arr.size <= 1 -%}
        {%- assign render_colors = '' | split: '' -%}
        {%- comment -%} empty → render once {%- endcomment -%}
      {%- endif -%}

      {%- comment -%} Render once for no-color products {%- endcomment -%}
      {%- if render_colors.size == 0 -%}
        {%- assign render_colors_list = '___single___' | split: '||' -%}
      {%- else -%}
        {%- assign render_colors_list = render_colors -%}
      {%- endif -%}

      {% for active_color in render_colors_list %}
        {%- assign is_single = false -%}
        {%- if active_color == '___single___' -%}{%- assign is_single = true -%}{%- endif -%}

        {%- comment -%} Pick card image for this color {%- endcomment -%}
        {%- assign card_img = product.featured_image -%}
        {%- assign card_img2 = product.images[1] -%}
        {%- assign card_link = product.url -%}
        {%- unless is_single -%}
          {%- assign card_link = product.url -%}
          {%- assign encoded_color = active_color | url_encode -%}
          {%- assign card_link = card_link | append: '?color=' | append: encoded_color -%}
          {%- assign active_color_lower = active_color | downcase | strip -%}

          {%- comment -%} Step 1: try variant.featured_image for card_img {%- endcomment -%}
          {%- assign card_img_from_variant = null -%}
          {%- for variant in product.variants -%}
            {%- if col_opt_pos == 1 -%}{%- assign vcol2 = variant.option1 -%}{%- endif -%}
            {%- if col_opt_pos == 2 -%}{%- assign vcol2 = variant.option2 -%}{%- endif -%}
            {%- if col_opt_pos == 3 -%}{%- assign vcol2 = variant.option3 -%}{%- endif -%}
            {%- if vcol2 == active_color and variant.featured_image -%}
              {%- assign card_img_from_variant = variant.featured_image -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Step 2: if no variant image, scan alt text for first matching image {%- endcomment -%}
          {%- if card_img_from_variant -%}
            {%- assign card_img = card_img_from_variant -%}
          {%- else -%}
            {%- for img in product.images -%}
              {%- assign img_alt_lc = img.alt | downcase | strip -%}
              {%- if img_alt_lc contains active_color_lower -%}
                {%- assign card_img = img -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

          {%- comment -%} Step 3: find secondary image (2nd image for this color) via alt text {%- endcomment -%}
          {%- assign card_img2_found = false -%}
          {%- assign card_img2_count = 0 -%}
          {%- for img in product.images -%}
            {%- assign img_alt_lc2 = img.alt | downcase | strip -%}
            {%- if img_alt_lc2 contains active_color_lower -%}
              {%- if card_img2_count == 0 -%}
                {%- comment -%} First match = primary, skip {%- endcomment -%}
                {%- assign card_img2_count = 1 -%}
              {%- elsif card_img2_found == false -%}
                {%- assign card_img2 = img -%}
                {%- assign card_img2_found = true -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} Fallback: try variant images for secondary {%- endcomment -%}
          {%- unless card_img2_found -%}
            {%- for variant in product.variants -%}
              {%- if col_opt_pos == 1 -%}{%- assign vcol3 = variant.option1 -%}{%- endif -%}
              {%- if col_opt_pos == 2 -%}{%- assign vcol3 = variant.option2 -%}{%- endif -%}
              {%- if col_opt_pos == 3 -%}{%- assign vcol3 = variant.option3 -%}{%- endif -%}
              {%- if vcol3 == active_color and variant.image and card_img2_found == false -%}
                {%- if variant.image != card_img -%}
                  {%- assign card_img2 = variant.image -%}
                  {%- assign card_img2_found = true -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endunless -%}
        {%- endunless -%}

        <div class="grid-item">
          <div class="image-wrapper relative">
            <!-- Main Image -->
            {% if card_img %}
                <a href="{{ card_link }}"
                  ><img
                    src="{{ card_img | img_url: '600x' }}"
                    class="img-primary main-product-image"
                    alt="{{ product.title }}"
                    data-main-image
                ></a>
            {% else %}
                <a href="{{ card_link }}">{{ 'product-1' | placeholder_svg_tag }}</a>
            {% endif %}

            <!-- Secondary Hover Image -->
            {% if card_img2 and card_img2 != card_img %}
                <a href="{{ card_link }}"
                  ><img src="{{ card_img2 | img_url: '600x' }}" class="img-secondary" alt="{{ product.title }}"
                ></a>
            {% endif %}

            <div
              class="bookmark-icon"
              data-product-id="{{ product.id }}"
              data-title="{{ product.title | escape }}"
              data-vendor="{{ product.vendor | escape }}"
              data-price="{{ product.price }}"
              data-image="{{ card_img | img_url: '600x' }}"
              data-url="{{ card_link }}"
              title="Add to Wishlist"
            >
              <svg width="14" height="18" viewBox="0 0 14 18" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M1 1v16l6-4 6 4V1H1z"/>
              </svg>
            </div>

            <div class="size-overlay">
              {% assign size_option_index = -1 %}
              {% for option in product.options_with_values %}
                {% assign downcased_name = option.name | downcase | strip %}
                {% if downcased_name == 'size' %}
                  {% assign size_option_index = forloop.index0 %}
                  {% for value in option.values %}
                    {% assign is_avail = false %}
                    {% assign avail_variant_id = '' %}
                    {% for variant in product.variants %}
                      {% if variant.options[size_option_index] == value and variant.available %}
                        {%- unless is_single -%}
                          {%- if col_opt_pos == 1 -%}{%- assign vcol_sz = variant.option1 -%}{%- endif -%}
                          {%- if col_opt_pos == 2 -%}{%- assign vcol_sz = variant.option2 -%}{%- endif -%}
                          {%- if col_opt_pos == 3 -%}{%- assign vcol_sz = variant.option3 -%}{%- endif -%}
                          {%- if vcol_sz == active_color -%}
                            {% assign is_avail = true %}
                            {% assign avail_variant_id = variant.id %}
                            {% break %}
                          {%- endif -%}
                        {%- else -%}
                          {% assign is_avail = true %}
                          {% assign avail_variant_id = variant.id %}
                          {% break %}
                        {%- endunless -%}
                      {% endif %}
                    {% endfor %}
                    {% if is_avail %}
                      <span class="size-avail" data-variant-id="{{ avail_variant_id }}">{{ value }}</span>
                    {% else %}
                      <span class="size-unavail">{{ value }}</span>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endfor %}
            </div>
          </div>

          <div class="item-info">
            <div class="item-vendor">{{ product.vendor | default: shop.name }}</div>
            <div class="item-title">
                <a href="{{ card_link }}" style="text-decoration: none; color: inherit;">
                  {{- product.title -}}
                  {%- unless is_single %} — {{ active_color }}{% endunless -%}
                </a>
            </div>
            <div class="item-price">
              {% if product.compare_at_price > product.price %}
                <span class="price-compare">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                <span class="price-sale">{{ product.price | money_without_trailing_zeros }}</span>
              {% else %}
                <span class="price-regular">{{ product.price | money_without_trailing_zeros }}</span>
              {% endif %}
            </div>

            {%- comment -%} Color swatches — each links to ?color=X {%- endcomment -%}
            <div class="item-swatches">
              {%- if col_opt and unique_color_arr.size > 1 -%}
                {%- assign sw_shown = 0 -%}
                {%- for sw_color in unique_color_arr -%}
                  {%- if sw_shown < 4 -%}
                    {%- assign sw_img = '' -%}
                    {%- for variant in product.variants -%}
                      {%- if col_opt_pos == 1 -%}{%- assign vcol_sw = variant.option1 -%}{%- endif -%}
                      {%- if col_opt_pos == 2 -%}{%- assign vcol_sw = variant.option2 -%}{%- endif -%}
                      {%- if col_opt_pos == 3 -%}{%- assign vcol_sw = variant.option3 -%}{%- endif -%}
                      {%- if vcol_sw == sw_color and variant.image -%}
                        {%- assign sw_img = variant.image | img_url: '600x' -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- assign sw_enc = sw_color | url_encode -%}
                    {%- assign sw_href = product.url | append: '?color=' | append: sw_enc -%}
                    {%- if active_color == sw_color -%}
                      <a
                        href="{{ sw_href }}"
                        class="swatch swatch-active"
                        style="background-color: {{ sw_color | handleize }}; {% if sw_img != '' %}background-image: url({{ sw_img }});{% endif %}"
                        title="{{ sw_color }}"
                      ></a>
                    {%- else -%}
                      <a
                        href="{{ sw_href }}"
                        class="swatch"
                        style="background-color: {{ sw_color | handleize }}; {% if sw_img != '' %}background-image: url({{ sw_img }});{% endif %}"
                        title="{{ sw_color }}"
                      ></a>
                    {%- endif -%}
                    {%- assign sw_shown = sw_shown | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if unique_color_arr.size > 4 -%}
                  <span style="font-size:10px;color:#888;margin-left:4px;"
                    >+{{ unique_color_arr.size | minus: 4 -}}
                  </span>
                {%- endif -%}
              {%- else -%}
                {%- comment -%} No color option → original swatch logic {%- endcomment -%}
                {%- assign color_option_index = -1 -%}
                {%- assign colors_shown = 0 -%}
                {%- for option in product.options_with_values -%}
                  {%- assign downcased_name = option.name | downcase -%}
                  {%- if downcased_name == 'color' or downcased_name == 'colour' -%}
                    {%- assign color_option_index = forloop.index0 -%}
                    {%- for value in option.values -%}
                      {%- if colors_shown < 4 -%}
                        {%- assign variant_image = '' -%}
                        {%- for variant in product.variants -%}
                          {%- if variant.options[color_option_index] == value and variant.image -%}
                            {%- assign variant_image = variant.image | img_url: '600x' -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                        <div
                          class="swatch"
                          style="background-color: {{ value | handleize }}; {% if variant_image != '' %}background-image: url({{ variant_image }});{% endif %}"
                          title="{{ value }}"
                          {% if variant_image != '' %}
                            data-image="{{ variant_image }}"
                          {% endif %}
                        ></div>
                        {%- assign colors_shown = colors_shown | plus: 1 -%}
                      {%- endif -%}
