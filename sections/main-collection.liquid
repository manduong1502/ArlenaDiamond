  <!-- ADD TO CART TOAST -->
  <div
    id="atc-toast"
    style="
      position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: #111; color: #fff; padding: 12px 24px; border-radius: 4px;
      font-family: var(--font-base); font-size: 13px; letter-spacing: 0.5px;
      opacity: 0; transition: all 0.3s ease; z-index: 9999; pointer-events: none;
      white-space: nowrap;
    "
  >
    Added to bag ✓
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      /* ── Format money (AUD) ── */
      function formatMoney(cents) {
        return 'A$' + Math.round(cents / 100).toLocaleString('en-AU');
      }

      /* ── Update cart badge ── */
      function updateCartBadge(count) {
        var badge = document.querySelector('.cart-badge');
        var cartBtn = document.getElementById('cartBtn');
        if (!cartBtn) return;
        if (count > 0) {
          if (badge) {
            badge.textContent = count;
          } else {
            badge = document.createElement('span');
            badge.className = 'cart-badge';
            badge.textContent = count;
            cartBtn.appendChild(badge);
          }
        } else {
          if (badge) badge.remove();
        }
      }

      /* ── Render cart items into overlay ── */
      function renderCartItems(cart) {
        var itemsContainer = document.querySelector('.cart-items');
        var headerCount = document.querySelector('.cart-header span span');
        var totalEl = document.querySelector('.cart-footer .cart-total-price');

        if (headerCount) {
          headerCount.textContent = String(cart.item_count).padStart(2, '0');
        }

        if (!itemsContainer) return;

        if (cart.items.length === 0) {
          itemsContainer.innerHTML =
            '<div style="font-size:11px;border-bottom:1px solid #000;padding:15px 20px;text-transform:uppercase;">YOUR SHOPPING BAG IS EMPTY</div>';
          return;
        }

        var html = '';
        cart.items.forEach(function (item, idx) {
          var imgHtml = item.image
            ? '<img src="' +
              item.image +
              '" style="width:100%;height:100%;object-fit:cover;mix-blend-mode:multiply;" />'
            : '';
          var optionsHtml = '';
          item.options_with_values.forEach(function (opt) {
            if (opt.value !== 'Default Title') {
              optionsHtml +=
                '<div style="margin-bottom:6px;">' + opt.name.toUpperCase() + ': ' + opt.value.toUpperCase() + '</div>';
            }
          });
          html +=
            '<div class="cart-item" style="display:flex;flex-direction:column;width:100%;font-size:11px;text-transform:uppercase;border-bottom:1px solid #000;">' +
            '<div style="display:flex;justify-content:space-between;padding:10px;">' +
            '<a href="' +
            item.url +
            '" style="color:blue;text-decoration:none;">' +
            item.product_title +
            '</a>' +
            '<span>' +
            formatMoney(item.final_line_price) +
            '</span>' +
            '</div>' +
            '<div style="display:flex;gap:15px;">' +
            '<div style="width:120px;height:160px;flex-shrink:0;background:#e0e6ed;display:flex;align-items:center;justify-content:center;">' +
            imgHtml +
            '</div>' +
            '<div style="flex:1;display:flex;flex-direction:column;">' +
            optionsHtml +
            '<div style="display:flex;background:#fff;text-align:center;font-size:11px;margin-top:auto;border-top:1px solid #eaeaea;width:100%;">' +
            '<button onclick="changeQty(' +
            (idx + 1) +
            ',' +
            (item.quantity - 1) +
            ')" style="flex:1;padding:8px 0;cursor:pointer;border:none;background:none;font-size:16px;">–</button>' +
            '<span style="flex:1;padding:8px 0;background:#f4f4f4;">' +
            item.quantity +
            '</span>' +
            '<button onclick="changeQty(' +
            (idx + 1) +
            ',' +
            (item.quantity + 1) +
            ')" style="flex:1;padding:8px 0;cursor:pointer;border:none;background:none;font-size:16px;">+</button>' +
            '</div></div></div>' +
            '<div style="display:flex;justify-content:space-between;padding:5px;color:blue;cursor:pointer;">' +
            '<span style="color:blue;cursor:pointer;">+ MOVE TO WISHLIST</span>' +
            '<a href="/cart/change?line=' +
            (idx + 1) +
            '&quantity=0" style="text-decoration:none;color:blue;">X REMOVE</a>' +
            '</div></div>';
        });
        itemsContainer.innerHTML = html;

        if (totalEl) totalEl.textContent = formatMoney(cart.total_price);
      }

      /* ── Change qty helper ── */
      window.changeQty = function (line, qty) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ line: line, quantity: qty }),
        })
          .then(function (r) {
            return r.json();
          })
          .then(function (cart) {
            renderCartItems(cart);
            updateCartBadge(cart.item_count);
          });
      };

      /* ── Open cart overlay ── */
      function openCart() {
        var overlay = document.getElementById('cartOverlay');
        if (overlay) {
          overlay.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      /* ── Show toast ── */
      function showToast(msg) {
        var toast = document.getElementById('atc-toast');
        if (!toast) return;
        toast.textContent = msg || 'Added to bag ✓';
        toast.style.opacity = '1';
        toast.style.transform = 'translateX(-50%) translateY(0)';
        setTimeout(function () {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(-50%) translateY(20px)';
        }, 2500);
      }

      /* ── Handle size click → add to cart ── */
      document.querySelectorAll('.size-avail').forEach(function (span) {
        span.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();

          var variantId = this.dataset.variantId;
          if (!variantId) return;

          // Visual: underline selected
          var overlay = this.closest('.size-overlay');
          if (overlay) {
            overlay.querySelectorAll('.size-avail').forEach(function (s) {
              s.style.textDecoration = 'none';
            });
          }
          this.style.textDecoration = 'underline';
          this.style.textUnderlineOffset = '3px';

          var clickedSpan = this;
          clickedSpan.style.pointerEvents = 'none';
          clickedSpan.textContent = '...';

          // Add to cart
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(variantId), quantity: 1 }),
          })
            .then(function (res) {
              return res.json();
            })
            .then(function () {
              return fetch('/cart.js');
            })
            .then(function (res) {
              return res.json();
            })
            .then(function (cart) {
              updateCartBadge(cart.item_count);
              renderCartItems(cart);
              openCart();
            })
            .catch(function (err) {
              console.error('Cart error:', err);
              showToast('Could not add to bag');
            })
            .finally(function () {
              clickedSpan.style.pointerEvents = 'auto';
            });
        });
      });
    });
  </script>
<style>
