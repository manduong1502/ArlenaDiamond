<style>
  /* Arlena CSS for Homepage */
  .arlena-home {
    background-color: #fff;
    color: #111;
    font-family: var(--font-base);
    margin-top: 78px; /* account for fixed header + topbar */
  }
  @media (max-width: 991px) {
    .arlena-home {
      margin-top: 61px;
    }
  }

  /* Hero Section */
  .hero-banner {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 500px;
    background-color: #0b0b0b;
    background-image: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 45%, rgba(0,0,0,0.15) 100%), url('{{ 'hero_jewelry.png' | asset_url }}');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: #fff;
    text-align: left;
    padding: 0 80px;
  }
  .hero-content {
    max-width: 560px;
  }
  .hero-title {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: clamp(34px, 5.5vw, 56px);
    font-weight: 400;
    margin-bottom: 20px;
    letter-spacing: 1.5px;
    line-height: 1.25;
    color: #ffffff;
  }
  .hero-title span {
    font-style: italic;
    font-family: 'Playfair Display', serif;
    color: #c5a880;
  }
  .hero-subtitle {
    font-size: 14px;
    color: #dedede;
    margin-bottom: 35px;
    letter-spacing: 0.5px;
    line-height: 1.6;
    max-width: 480px;
    margin-left: 0;
    margin-right: auto;
  }
  .hero-ctas {
    display: flex;
    justify-content: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  .btn-gold {
    background-color: #c5a880;
    color: #000;
    border: 1px solid #c5a880;
    padding: 12px 30px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }
  .btn-gold:hover {
    background-color: #bfa37a;
    border-color: #bfa37a;
    color: #000;
  }
  .btn-outline-white {
    background-color: transparent;
    color: #fff;
    border: 1px solid #fff;
    padding: 12px 30px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }
  .btn-outline-white:hover {
    background-color: #fff;
    color: #000;
  }

  /* Collections Section */
  .home-collections {
    background-color: #fdfaf6; /* Match light cream background */
    padding: 60px 20px;
    text-align: center;
  }
  .section-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: #c5a880;
    text-transform: uppercase;
    font-weight: 600;
    display: block;
    margin-bottom: 8px;
  }
  .section-title {
    font-family: 'Cinzel', serif;
    font-size: 24px;
    letter-spacing: 1.5px;
    margin-bottom: 12px;
    color: #111;
  }
  .divider-diamond {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-bottom: 40px;
  }
  .divider-diamond::before,
  .divider-diamond::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background-color: #c5a880;
    opacity: 0.7;
  }
  .divider-diamond span {
    display: block;
    width: 6px;
    height: 6px;
    background-color: #c5a880;
    transform: rotate(45deg);
  }
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 15px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .collection-card {
    position: relative;
    aspect-ratio: 1/1; /* Square card */
    background-color: #000;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    text-decoration: none;
  }
  .collection-card img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .collection-card:hover img {
    transform: scale(1.05);
  }
  /* Subtle bottom gradient shadow to ensure text readability */
  .collection-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .collection-card-content {
    position: relative;
    z-index: 2;
    padding: 20px 10px;
    text-align: center;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .collection-card-content h4 {
    color: #ffffff;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0;
  }
  .collection-card-content span {
    color: #c5a880;
    font-size: 10px;
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.5px;
    display: inline-block;
  }
  @media (max-width: 991px) {
    .collections-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
  }
  @media (max-width: 575px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .collections-grid a:last-child {
      grid-column: span 2;
    }
  }

  /* Crafted Section */
  .crafted-section {
    background-color: #000000;
    color: #fff;
    display: flex;
    align-items: stretch;
    width: 100%;
    margin: 0;
  }
  .crafted-img-col {
    width: 35%; /* Left column */
    background-image: url('{{ 'handcraft_jewelry.png' | asset_url }}');
    background-size: cover;
    background-position: center;
    min-height: 380px;
    flex-shrink: 0;
  }
  .crafted-content-col {
    width: 65%; /* Right column */
    padding: 50px 60px;
    display: flex;
    flex-direction: row;
    gap: 40px;
    align-items: center;
    background-color: #000000;
  }
  .crafted-info-block {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .crafted-bullets-block {
    flex: 0.8;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .crafted-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: #c5a880;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
    display: block;
  }
  .crafted-title {
    font-family: 'Cinzel', serif;
    font-size: 24px;
    letter-spacing: 1.5px;
    margin-bottom: 20px;
    color: #fff;
    line-height: 1.35;
    text-transform: uppercase;
  }
  .crafted-desc {
    font-size: 12px;
    line-height: 1.7;
    color: #b0b0b0;
    margin-bottom: 16px;
  }
  .crafted-desc:last-child {
    margin-bottom: 0;
  }
  .btn-gold-block {
    display: inline-block;
    background-color: #c5a880;
    color: #000;
    padding: 12px 25px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.3s ease;
    border: none;
    margin-top: 15px;
  }
  .btn-gold-block:hover {
    background-color: #b3956d;
  }
  .crafted-bullets {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  .crafted-bullet-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .crafted-bullet-item:first-child {
    padding-top: 0;
  }
  .crafted-bullet-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }
  .crafted-bullet-item i {
    color: #c5a880;
    font-size: 24px;
    flex-shrink: 0;
  }
  .crafted-bullet-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .crafted-bullet-text strong {
    font-size: 11px;
    letter-spacing: 0.5px;
    color: #fff;
    font-weight: 600;
    text-transform: uppercase;
  }
  .crafted-bullet-text span {
    font-size: 10px;
    color: #888;
  }
  @media (max-width: 991px) {
    .crafted-section {
      flex-direction: column;
    }
    .crafted-img-col {
      width: 100%;
      height: 300px;
    }
    .crafted-content-col {
      width: 100%;
      padding: 40px 25px;
      flex-direction: column;
      gap: 30px;
    }
  }

  /* Moments Section */
  .moments-section {
    background-color: #fdfaf6;
    padding: 60px 40px;
  }
  .moments-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 40px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }
  .moments-text-col {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .moments-text-col h3 {
    font-family: 'Cinzel', serif;
    font-size: 20px;
    letter-spacing: 1px;
    line-height: 1.35;
    text-transform: uppercase;
    color: #111;
  }
  .moments-signature {
    font-family: 'Mr De Haviland', cursive;
    font-size: 52px;
    color: #c5a880;
    margin-top: -10px;
    font-weight: normal;
  }
  .moments-images-col {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .moment-img-card {
    aspect-ratio: 1/1;
    overflow: hidden;
    background-color: #000;
  }
  .moment-img-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .moment-img-card:hover img {
    transform: scale(1.05);
  }
  @media (max-width: 991px) {
    .moments-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .moments-images-col {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<div class="arlena-home full-width">
  <!-- 1. Hero Banner -->
  <section class="hero-banner">
    <div class="hero-content">
      <h2 class="hero-title">Made <span>for</span> Moments.</h2>
      <p class="hero-subtitle">
        Australian made fine jewellery. crafted to order for life's most meaningful moments.
      </p>
      <div class="hero-ctas">
        <a href="/collections/engagement-rings" class="btn-gold">Shop Engagement Rings</a>
        <a href="/collections/all" class="btn-outline-white">Shop All Jewellery</a>
      </div>
    </div>
  </section>

  <!-- 2. Explore Our Collections -->
  <section class="home-collections">
    <span class="section-label">Explore Our Collections</span>
    <h3 class="section-title">Timeless Pieces, Crafted for You</h3>
    <div class="divider-diamond"><span></span></div>
    
    <div class="collections-grid">
      <a href="/collections/engagement-rings" class="collection-card">
        <img src="{{ 'cat_engagement.png' | asset_url }}" alt="Engagement Rings" loading="lazy">
        <div class="collection-card-content">
          <h4>Engagement Rings</h4>
          <span>View Collection</span>
        </div>
      </a>
      <a href="/collections/wedding-bands" class="collection-card">
        <img src="{{ 'cat_wedding.png' | asset_url }}" alt="Wedding Bands" loading="lazy">
        <div class="collection-card-content">
          <h4>Wedding Bands</h4>
          <span>View Collection</span>
        </div>
      </a>
      <a href="/collections/earrings" class="collection-card">
        <img src="{{ 'cat_earrings.png' | asset_url }}" alt="Earrings" loading="lazy">
        <div class="collection-card-content">
          <h4>Earrings</h4>
          <span>View Collection</span>
        </div>
      </a>
      <a href="/collections/pendants" class="collection-card">
        <img src="{{ 'cat_pendants.png' | asset_url }}" alt="Pendants" loading="lazy">
        <div class="collection-card-content">
          <h4>Pendants</h4>
          <span>View Collection</span>
        </div>
      </a>
      <a href="/collections/bracelets" class="collection-card">
        <img src="{{ 'cat_bracelets.png' | asset_url }}" alt="Bracelets" loading="lazy">
        <div class="collection-card-content">
          <h4>Bracelets</h4>
          <span>View Collection</span>
        </div>
      </a>
    </div>
  </section>

  <!-- 3. Crafted in Australia -->
  <section class="crafted-section">
    <div class="crafted-img-col"></div>
    <div class="crafted-content-col">
      <div class="crafted-info-block">
        <span class="crafted-label">Crafted in Australia</span>
        <h3 class="crafted-title">CRAFTED WITH EXPERIENCE AND PRECISION</h3>
        <p class="crafted-desc">
          Each piece is made to order in Australia, combining modern jewellery-making technology with traditional craftsmanship. At the heart of our process is our Master Jeweller, with more than 20 years of experience, who oversees the skilled craftsmanship behind every piece.
        </p>
        <p class="crafted-desc">
          From precision design and casting to stone setting, finishing and final inspection, every step is approached with care, attention to detail and a commitment to exceptional quality.
        </p>
        <div>
          <a href="/pages/our-story" class="btn-gold-block">Learn More About Our Story</a>
        </div>
      </div>
      
      <div class="crafted-bullets-block">
        <div class="crafted-bullets">
          <div class="crafted-bullet-item">
            <i class="fa-regular fa-gem"></i>
            <div class="crafted-bullet-text">
              <strong>Ethically Sourced</strong>
              <span>Diamonds & Gemstones</span>
            </div>
          </div>
          <div class="crafted-bullet-item">
            <i class="fa-solid fa-screwdriver-wrench"></i>
            <div class="crafted-bullet-text">
              <strong>Precision Craftsmanship</strong>
              <span>by Skilled Jewellers</span>
            </div>
          </div>
          <div class="crafted-bullet-item">
            <i class="fa-regular fa-heart"></i>
            <div class="crafted-bullet-text">
              <strong>Personalised Service</strong>
              <span>Online, Always</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Designed for Life's Moments -->
  <section class="moments-section">
    <div class="moments-grid">
      <div class="moments-text-col">
        <span class="section-label">Designed for Life's</span>
        <h3>Most Meaningful Moments</h3>
        <p style="font-size: 12px; color: #555; line-height: 1.5; margin: 0;">
          From the moment you say yes, to every milestone that follows, we're here to be part of your story.
        </p>
        <span class="moments-signature">Arlena</span>
      </div>
      <div class="moments-images-col">
        <div class="moment-img-card">
          <img src="{{ 'moments_ring_box.png' | asset_url }}" alt="Moments 1">
        </div>
        <div class="moment-img-card">
          <img src="{{ 'moments_ring_hand.png' | asset_url }}" alt="Moments 2">
        </div>
        <div class="moment-img-card">
          <img src="{{ 'moments_necklace.png' | asset_url }}" alt="Moments 3">
        </div>
        <div class="moment-img-card">
          <img src="{{ 'moments_wedding_bands.png' | asset_url }}" alt="Moments 4">
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Main Index",
  "settings": []
}
{% endschema %}
