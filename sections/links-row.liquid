<section class="links-row full-width" style="display: flex; gap: 0; overflow-x: auto;">
  {% for block in section.blocks %}
    <a href="{{ block.settings.link }}" class="link-col" {{ block.shopify_attributes }}>
      {% if block.settings.image %}
        <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title }}" />
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
      <div class="link-text" style="font-weight: bold; margin-top: 10px;">{{ block.settings.title | upcase }}</div>
    </a>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Featured Links Grid",
  "settings": [],
  "blocks": [
    {
      "type": "link_item",
      "name": "Link Column",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Link Title" },
        { "type": "url", "id": "link", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Links Grid",
      "blocks": [
        { "type": "link_item" },
        { "type": "link_item" },
        { "type": "link_item" },
        { "type": "link_item" },
        { "type": "link_item" }
      ]
    }
  ]
}
{% endschema %}
