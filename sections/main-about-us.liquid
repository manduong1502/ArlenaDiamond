<div class="policy-page full-width">
  <div class="policy-page-inner">
    <h1 class="policy-page-title">{{ page.title }}</h1>
    <div class="policy-page-content">
      {% if page.content != blank %}
        {{ page.content }}
      {% else %}
        <h2>ABOUT ARLENA</h2>
        <p>At Arlena, we bring together modern jewellery-making technology and time-honoured craftsmanship to create exceptional fine jewellery in Australia. Each piece is made to order with care, precision and attention to detail.</p>

        <p>Guided by our Master Jeweller with over 20 years of experience, every design is thoughtfully crafted to showcase the brilliant beauty of ethically sourced diamonds and precious metals.</p>

        <h2>GET IN TOUCH</h2>
        <p>Our team is dedicated to providing personalized service to guide you through your jewellery selection, custom orders, or any inquiries.</p>
        <p>Please feel free to reach out to us at <a href="mailto:hello@arlena.com.au">hello@arlena.com.au</a> and our team will be delighted to assist you.</p>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .policy-page { background: #fff; min-height: 60vh; }
  .policy-page-inner { max-width: 800px; margin: 0 auto; padding: 120px 40px 80px; }
  .policy-page-title {
    font-family: var(--font-base); font-size: 28px; font-weight: 500;
    letter-spacing: 2px; text-transform: uppercase; color: #111;
    margin-bottom: 40px; padding-bottom: 20px; border-bottom: 1px solid #e0e0e0;
  }
  .policy-page-content { font-family: var(--font-base); font-size: 14px; line-height: 1.8; color: #333; }
  .policy-page-content h2, .policy-page-content h3 { font-size: 18px; font-weight: 600; margin: 30px 0 15px; color: #111; }
  .policy-page-content p { margin-bottom: 16px; }
  .policy-page-content a { color: #111; text-decoration: underline; text-underline-offset: 3px; }
  .policy-page-content ul, .policy-page-content ol { padding-left: 20px; margin-bottom: 16px; }
  .policy-page-content li { margin-bottom: 8px; }
  @media (max-width: 768px) {
    .policy-page-inner { padding: 100px 20px 60px; }
    .policy-page-title { font-size: 20px; letter-spacing: 1px; }
  }
</style>

{% schema %}
{
  "name": "About Us",
  "settings": [],
  "presets": [{ "name": "About Us" }]
}
{% endschema %}
