<!-- PASS VARIANTS DATA TO JAVASCRIPT FOR DYNAMIC OPTION MATCHING -->
<script>
  window.pdpVariantsJson = {{ product.variants | json }};
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    /* --- 1. Gallery thumbnail switching --- */
    var thumbs = document.querySelectorAll('.angara-thumb');
    var mainImg = document.getElementById('angara-main-img');
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');
        if (mainImg) {
          mainImg.src = this.dataset.src;
        }
      });
    });

    /* --- 2. Tab selection triggers for bottom panel --- */
    var tabBtns = document.querySelectorAll('.spec-tab-btn');
    var tabPanes = document.querySelectorAll('.tab-pane');
    tabBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        tabBtns.forEach(function(b) { b.classList.remove('active'); });
        tabPanes.forEach(function(p) { p.classList.remove('active'); });
        
        this.classList.add('active');
        var targetPane = document.getElementById('tab-' + this.dataset.tab);
        if (targetPane) {
          targetPane.classList.add('active');
        }
      });
    });

    /* --- 3. Dynamic variant selection logic matching real variants array --- */
    var variants = window.pdpVariantsJson || [];
    var optionBlocks = document.querySelectorAll('.angara-option-block[data-option-index]');
    
    // Store current state of selected options
    var currentSelections = {};
    optionBlocks.forEach(function(block) {
      var idx = block.dataset.optionIndex;
      var activeBtn = block.querySelector('.angara-opt-btn.active');
      if (activeBtn) {
        currentSelections[idx] = activeBtn.dataset.value;
      }
    });

    // Listen to option button clicks
    optionBlocks.forEach(function(block) {
      var idx = block.dataset.optionIndex;
      var labelSpan = block.querySelector('.lbl-selected-value');
      var buttons = block.querySelectorAll('.angara-opt-btn');
      
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          buttons.forEach(function(b) { b.classList.remove('active'); });
          this.classList.add('active');
          
          var selectedVal = this.dataset.value;
          currentSelections[idx] = selectedVal;
          if (labelSpan) labelSpan.textContent = selectedVal;
          
          updateSelectedVariant();
        });
      });
    });



    var priceEl = document.getElementById('visible-price');
    var summaryPriceEl = document.getElementById('atc-btn-price-summary');
    var atcBtn = document.getElementById('pdp-atc-btn');
    var variantInput = document.getElementById('pdp-variant-id');
    
    // Spec table dynamic spans
    var specDimType = document.getElementById('spec-val-diamond-type');
    var specCarat = document.getElementById('spec-val-carat');
    var specMetal = document.getElementById('spec-val-metal');

    function updateSelectedVariant() {
      if (variants.length === 0) return;

      // Find matching variant
      var matchedVariant = variants.find(function(variant) {
        var match = true;
        Object.keys(currentSelections).forEach(function(idx) {
          var valIndex = parseInt(idx);
          var selectedValue = currentSelections[idx];
          
          // Shopify variant options are indexed as option1, option2, option3
          var variantOptionValue = variant['option' + (valIndex + 1)];
          if (variantOptionValue !== selectedValue) {
            match = false;
          }
        });
        return match;
      });

      if (matchedVariant) {
        // Update price
        var formattedPrice = 'AUD $' + (matchedVariant.price / 100).toLocaleString('en-US');
        if (priceEl) priceEl.textContent = formattedPrice;
        if (summaryPriceEl) summaryPriceEl.textContent = formattedPrice;
        
        // Update input ID for Add To Cart
        if (variantInput) variantInput.value = matchedVariant.id;
        
        // Enable button
        if (atcBtn) {
          atcBtn.disabled = !matchedVariant.available;
          atcBtn.querySelector('span').textContent = matchedVariant.available ? 'ADD TO CART' : 'SOLD OUT';
        }

        // Dynamic specifications update
        if (specDimType && currentSelections['1']) {
          specDimType.textContent = currentSelections['1'] + ' (Natural/Lab Grown selection)';
        }
        if (specCarat && currentSelections['2']) {
          var caratSelected = currentSelections['2'];
          var halfCaratDetails = caratSelected === '0.50ct' ? '0.25ct Emerald + 0.25ct Pear' :
                                 caratSelected === '2.00ct' ? '1.00ct Emerald + 1.00ct Pear' :
                                 '0.50ct Emerald + 0.50ct Pear';
          specCarat.textContent = caratSelected + ' total (' + halfCaratDetails + ')';
        }
        if (specMetal && currentSelections['0']) {
          specMetal.textContent = currentSelections['0'];
        }

        // Change main image if variant has featured image
        if (matchedVariant.featured_image && mainImg) {
          mainImg.src = matchedVariant.featured_image.src;
          // De-select active thumbnail since we updated via variant select
          thumbs.forEach(function(t) { t.classList.remove('active'); });
        }
      } else {
        // No match found
        if (atcBtn) {
          atcBtn.disabled = true;
          atcBtn.querySelector('span').textContent = 'UNAVAILABLE';
        }
      }
    }

    // Run once at start to bind initial values
    updateSelectedVariant();

    // Custom Ring Size buttons logic
    var sizeBtns = document.querySelectorAll('#ring-size-buttons .size-btn');
    var lblRingSize = document.getElementById('lbl-ring-size');
    var ringSizeInput = document.getElementById('pdp-ring-size-property');
    var sizeContainer = document.getElementById('ring-size-buttons');
    var prevSizeBtn = document.getElementById('prev-size-btn');
    var nextSizeBtn = document.getElementById('next-size-btn');

    if (sizeBtns.length > 0) {
      sizeBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          sizeBtns.forEach(function(b) { b.classList.remove('active'); });
          this.classList.add('active');
          var selectedSize = this.dataset.value;
          if (lblRingSize) lblRingSize.textContent = selectedSize;
          if (ringSizeInput) ringSizeInput.value = selectedSize;
        });
      });
    }

    // Scroll buttons logic for size slider
    if (sizeContainer && prevSizeBtn && nextSizeBtn) {
      prevSizeBtn.addEventListener('click', function() {
        sizeContainer.scrollBy({ left: -120, behavior: 'smooth' });
      });
      nextSizeBtn.addEventListener('click', function() {
        sizeContainer.scrollBy({ left: 120, behavior: 'smooth' });
      });
    }

    // Engraving toggle logic
    var engravingToggle = document.getElementById('engraving-toggle');
    var engravingPanel = document.getElementById('engraving-panel');
    if (engravingToggle && engravingPanel) {
      engravingToggle.addEventListener('click', function() {
        var isExpanded = engravingPanel.style.display !== 'none';
        if (isExpanded) {
          engravingPanel.style.display = 'none';
          engravingToggle.classList.remove('expanded');
          engravingToggle.querySelector('.toggle-icon').textContent = '+';
        } else {
          engravingPanel.style.display = 'block';
          engravingToggle.classList.add('expanded');
          engravingToggle.querySelector('.toggle-icon').textContent = '-';
        }
      });
    }

    /* --- 4. Wishlist Button Toggle --- */
    var wishlistBtn = document.getElementById('pdp-wishlist-btn');
    if (wishlistBtn) {
      wishlistBtn.addEventListener('click', function() {
        this.classList.toggle('active');
        var icon = this.querySelector('i');
        if(this.classList.contains('active')) {
          icon.className = 'fa-solid fa-heart';
          icon.style.color = '#cc0000';
        } else {
          icon.className = 'fa-regular fa-heart';
          icon.style.color = '';
        }
      });
    }

    /* --- 5. AJAX Add to Cart Submission --- */
    var form = document.getElementById('pdp-atc-form');
    if (form && atcBtn) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var id = variantInput ? variantInput.value : '';
        if (!id) return;

        var origContent = atcBtn.querySelector('span').textContent;
        atcBtn.querySelector('span').textContent = 'ADDING...';
        atcBtn.disabled = true;

        var payloadProperties = {};
        var ringSizeVal = ringSizeInput ? ringSizeInput.value : '';
        if (ringSizeVal) {
          payloadProperties['Ring Size'] = ringSizeVal;
        }

        var engravingTxtInput = document.getElementById('pdp-engraving-input');
        if (engravingTxtInput && engravingTxtInput.value.trim() !== '') {
          payloadProperties['Engraving'] = engravingTxtInput.value.trim();
        }

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: parseInt(id),
            quantity: 1,
            properties: payloadProperties
          }),
        })
        .then(function(r) { return r.json(); })
        .then(function() { return fetch('/cart.js'); })
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          if (typeof globalUpdateCartBadge === 'function') globalUpdateCartBadge(cart.item_count);
          if (typeof cartRenderItems === 'function') cartRenderItems(cart);
          if (typeof globalOpenCart === 'function') globalOpenCart();
          atcBtn.querySelector('span').textContent = 'ADDED ✓';
          setTimeout(function() {
            atcBtn.querySelector('span').textContent = origContent;
            atcBtn.disabled = false;
          }, 2000);
        })
        .catch(function(err) {
          console.error('ATC error', err);
          atcBtn.querySelector('span').textContent = origContent;
          atcBtn.disabled = false;
        });
      });
    }
  });
</script>

