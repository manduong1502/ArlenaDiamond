{%- assign current_variant = product.selected_or_first_available_variant -%}

<style>
  /* Angara-style PDP Styles */
  .angara-pdp {
    max-width: 1200px;
    margin: 140px auto 40px auto;
    padding: 0 20px;
    font-family: var(--font-base);
    color: #111;
    box-sizing: border-box;
  }
  @media (max-width: 991px) {
    .angara-pdp {
      margin-top: 110px;
    }
  }

  /* Breadcrumbs */
  .angara-breadcrumbs {
    font-size: 10px;
    color: #777;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .angara-breadcrumbs a {
    color: #777;
    text-decoration: none;
  }
  .angara-breadcrumbs a:hover {
    color: #000;
  }
  .angara-breadcrumbs span {
    margin: 0 5px;
    color: #ccc;
  }

  /* Main Layout Grid - 50/50 split with min-width safety for scrolling inputs */
  .angara-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 50px;
    align-items: start;
    margin-bottom: 50px;
  }
  @media (max-width: 991px) {
    .angara-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 30px;
    }
  }

  /* Gallery Column - Horizontal thumbnails below main viewport matching Image 2 */
  .angara-gallery {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 130px;
    width: 100%;
  }
  @media (max-width: 991px) {
    .angara-gallery {
      position: static;
    }
  }
  .angara-viewport {
    position: relative;
    border: 1px solid #f6f6f6;
    background-color: #fafaf9;
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .angara-viewport img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .angara-thumbs {
    display: flex;
    flex-direction: row;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 5px;
  }
  .angara-thumb {
    width: 80px;
    height: 80px;
    flex: 0 0 80px;
    border: 1px solid #eaeaea;
    cursor: pointer;
    overflow: hidden;
    background-color: #fafaf9;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s ease;
  }
  .angara-thumb.active,
  .angara-thumb:hover {
    border-color: #000;
  }
  .angara-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .angara-tag {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: #000;
    color: #fff;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 1px;
    padding: 4px 8px;
    text-transform: uppercase;
    z-index: 10;
  }

  /* Info Column */
  .angara-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .angara-pretitle {
    font-size: 11px;
    color: #777;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: underline;
  }
  .angara-title {
    font-family: 'Cinzel', serif;
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 1px;
    line-height: 1.3;
    margin: 0;
  }
  
  /* Rating star row */
  .angara-rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #666;
  }
  .angara-stars {
    color: #c5a880; /* Gold stars */
    font-size: 13px;
  }

  .angara-price-row {
    display: flex;
    align-items: baseline;
    gap: 15px;
    margin-top: 5px;
  }
  .angara-price {
    font-size: 24px;
    font-weight: 600;
    color: #111;
  }
  .angara-price-compare {
    font-size: 16px;
    text-decoration: line-through;
    color: #888;
  }
  .angara-desc-brief {
    font-size: 13px;
    line-height: 1.6;
    color: #555;
  }

  /* Service Badges directly below description */
  .pdp-badges-row {
    display: flex;
    gap: 15px;
    margin: 5px 0 15px 0;
    flex-wrap: wrap;
    border-top: 1px solid #eaeaea;
    border-bottom: 1px solid #eaeaea;
    padding: 12px 0;
  }
  .pdp-badge-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 500;
    color: #555;
  }
  .pdp-badge-item i {
    color: #c5a880;
  }

  /* Option Block */
  .angara-option-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .angara-option-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #111;
  }
  .angara-option-label span {
    font-weight: 400;
    color: #666;
    text-transform: none;
    margin-left: 5px;
  }

  /* Button selection style matching mockup (Image 4) */
  .angara-option-buttons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .angara-opt-btn {
    background-color: #fff;
    border: 1px solid #dcdad5;
    padding: 9px 18px;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #111;
    border-radius: 2px;
  }
  .angara-opt-btn:hover {
    border-color: #000;
  }
  .angara-opt-btn.active {
    border-color: #000;
    box-shadow: inset 0 0 0 1px #000;
  }

  /* Ring Size buttons and slider */
  .ring-size-slider-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
    width: 100%;
  }
  .ring-size-buttons-container {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
    flex-grow: 1;
    padding: 2px 0;
  }
  .ring-size-buttons-container::-webkit-scrollbar {
    display: none;
  }
  .size-btn {
    flex: 0 0 40px;
    height: 40px;
    background-color: #fff;
    border: 1px solid #dcdad5;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #111;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .size-btn:hover {
    border-color: #000;
  }
  .size-btn.active {
    border-color: #000;
    font-weight: bold;
    box-shadow: inset 0 0 0 1px #000;
  }
  .slider-arrow {
    background: #fff;
    border: 1px solid #dcdad5;
    cursor: pointer;
    width: 28px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    transition: all 0.2s ease;
    color: #666;
    z-index: 2;
  }
  .slider-arrow:hover {
    border-color: #000;
    color: #000;
  }

  /* Free Engraving style */
  .engraving-toggle-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 15px;
    background-color: #f7f6f4;
    border: 1px solid #e0dfdb;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #111;
    border-radius: 2px;
    transition: all 0.2s ease;
  }
  .engraving-toggle-header:hover {
    background-color: #f0eee9;
    border-color: #c5a880;
  }
  .engraving-toggle-header .toggle-icon {
    font-size: 14px;
    font-weight: bold;
    color: #666;
    transition: transform 0.2s ease;
  }
  .engraving-toggle-header.expanded .toggle-icon {
    transform: rotate(45deg);
  }
  .engraving-input-panel {
    border: 1px solid #e0dfdb;
    border-top: none;
    padding: 15px;
    background-color: #fff;
    border-radius: 0 0 2px 2px;
  }
  .engraving-text-input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #dcdad5;
    font-size: 12px;
    color: #111;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s ease;
    text-transform: uppercase;
  }
  .engraving-text-input:focus {
    border-color: #000;
  }
  .engraving-limit-text {
    font-size: 10px;
    color: #666;
    margin-top: 6px;
  }

  /* Purchase Info Row */
  .pdp-purchase-details {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 10px;
    font-size: 12px;
    color: #555;
  }
  .purchase-detail-item {
    display: flex;
    justify-content: space-between;
  }

  /* ATC and Consultation buttons */
  .pdp-action-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 15px;
  }
  .angara-atc-btn {
    width: 100%;
    background-color: #000;
    color: #fff;
    border: 1px solid #000;
    padding: 14px 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .angara-atc-btn:hover {
    background-color: #333;
    border-color: #333;
  }
  .angara-consult-btn {
    width: 100%;
    background-color: #fff;
    color: #111;
    border: 1px solid #000;
    padding: 14px 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .angara-consult-btn:hover {
    background-color: #faf9f8;
  }

  /* --- ABOUT THIS PIECE --- */
  .about-piece-section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 50px;
    align-items: center;
    margin: 80px 0;
    border-top: 1px solid #eaeaea;
    padding-top: 60px;
  }
  @media (max-width: 768px) {
    .about-piece-section {
      grid-template-columns: 1fr;
      gap: 30px;
      margin: 40px 0;
      padding-top: 40px;
    }
  }
  .about-content h2 {
    font-family: 'Cinzel', serif;
    font-size: 26px;
    font-weight: 400;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .about-content p {
    font-size: 13px;
    line-height: 1.8;
    color: #555;
    margin-bottom: 20px;
  }
  .about-img-wrap {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    background-color: #fafaf9;
    border: 1px solid #f6f6f6;
  }
  .about-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* --- BRAND ICONS ROW --- */
  .brand-icons-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    background-color: #fdfaf6; /* Warm cream background */
    padding: 40px 20px;
    border-top: 1px solid rgba(197, 168, 128, 0.2);
    border-bottom: 1px solid rgba(197, 168, 128, 0.2);
    margin: 50px 0;
    box-sizing: border-box;
  }
  @media (max-width: 991px) {
    .brand-icons-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }
  @media (max-width: 575px) {
    .brand-icons-row {
      grid-template-columns: 1fr;
      gap: 25px;
    }
  }
  .icon-block-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 10px;
  }
  .icon-block-item i {
    font-size: 24px;
    color: #c5a880; /* Gold */
    margin-bottom: 15px;
  }
  .icon-block-item h4 {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 10px 0;
    color: #111;
  }
  .icon-block-item p {
    font-size: 11px;
    line-height: 1.5;
    color: #555;
    margin: 0;
  }

  /* --- TAB ACCORDION LAYOUT SECTION --- */
  .specs-tabs-section {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 50px;
    margin: 60px 0 80px 0;
    align-items: start;
  }
  @media (max-width: 991px) {
    .specs-tabs-section {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
  .tabs-list-col {
    display: flex;
    flex-direction: column;
    border-left: 1px solid #eaeaea;
  }
  @media (max-width: 991px) {
    .tabs-list-col {
      flex-direction: row;
      border-left: none;
      border-bottom: 1px solid #eaeaea;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .tabs-list-col::-webkit-scrollbar {
      display: none;
    }
  }
  .spec-tab-btn {
    background: none;
    border: none;
    text-align: left;
    padding: 16px 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #777;
    cursor: pointer;
    border-left: 3px solid transparent;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
  }
  @media (max-width: 991px) {
    .spec-tab-btn {
      border-left: none;
      border-bottom: 3px solid transparent;
      padding: 12px 15px;
      white-space: nowrap;
      flex-shrink: 0;
    }
  }
  .spec-tab-btn i {
    font-size: 10px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .spec-tab-btn:hover {
    color: #111;
  }
  .spec-tab-btn.active {
    color: #111;
    border-left-color: #c5a880; /* Gold left border */
  }
  @media (max-width: 991px) {
    .spec-tab-btn.active {
      border-left-color: transparent;
      border-bottom-color: #c5a880;
    }
  }
  .spec-tab-btn.active i {
    opacity: 1;
  }
  
  .tab-content-col {
    min-height: 250px;
  }
  .tab-pane {
    display: none;
    animation: fadeIn 0.4s ease forwards;
  }
  .tab-pane.active {
    display: block;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Specifications Table style */
  .spec-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .spec-table tr {
    border-bottom: 1px solid #eaeaea;
  }
  .spec-table td {
    padding: 12px 10px;
  }
  .spec-table td.spec-label {
    font-weight: 600;
    color: #111;
    width: 250px;
  }
  .spec-table td.spec-val {
    color: #555;
  }
  @media (max-width: 575px) {
    .spec-table td.spec-label {
      width: 150px;
    }
  }

  .text-pane-content {
    font-size: 13px;
    line-height: 1.8;
    color: #555;
  }
  .text-pane-content p {
    margin-top: 0;
    margin-bottom: 15px;
  }
  .text-pane-content ul {
    padding-left: 20px;
    margin: 10px 0;
  }
  .text-pane-content li {
    margin-bottom: 8px;
  }

  /* --- LOVED STORIES & REVIEWS --- */
  .reviews-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #eaeaea;
    padding-bottom: 15px;
    margin-bottom: 30px;
  }
  .reviews-section-header h3 {
    font-family: 'Cinzel', serif;
    font-size: 20px;
    font-weight: 400;
    margin: 0;
  }
  .reviews-btn-all {
    background: none;
    border: 1px solid #111;
    padding: 8px 18px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .reviews-btn-all:hover {
    background-color: #111;
    color: #fff;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }
  @media (max-width: 991px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      gap: 15px;
    }
  }
  .review-card {
    background-color: #fafaf9;
    padding: 25px;
    border-radius: 2px;
  }
  .review-rating-row {
    font-size: 11px;
    color: #c5a880;
    margin-bottom: 15px;
  }
  .review-text {
    font-size: 12px;
    line-height: 1.6;
    color: #333;
    margin-bottom: 15px;
    font-style: italic;
  }
  .review-author {
    font-size: 11px;
    font-weight: 600;
    color: #777;
    margin-top: auto;
  }

  /* --- COMPLETE THE LOOK SECTION --- */
  .pdp-related-header {
    border-bottom: 1px solid #eaeaea;
    padding-bottom: 15px;
    margin-bottom: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .pdp-related-header h3 {
    font-family: 'Cinzel', serif;
    font-size: 20px;
    font-weight: 400;
    margin: 0;
  }
  
  .look-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    align-items: start;
    box-sizing: border-box;
  }
  @media (max-width: 991px) {
    .look-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 575px) {
    .look-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
  
  .look-item {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .look-img-wrap {
    width: 100%;
    aspect-ratio: 1/1;
    background-color: #fafaf9;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border: 1px solid #f6f6f6;
  }
  .look-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .look-item:hover .look-img-wrap img {
    transform: scale(1.03);
  }
  .look-info {
    padding: 12px 0;
    text-align: left;
  }
  .look-item-title {
    font-size: 11px;
    font-weight: 500;
    color: #111;
    line-height: 1.4;
    height: 32px;
    overflow: hidden;
    display: block;
    margin-bottom: 6px;
  }
  .look-item-price {
    font-size: 11px;
    font-weight: 600;
    color: #666;
  }

  .look-promo-card {
    background-color: #fdfaf6;
    border: 1px solid rgba(197, 168, 128, 0.25);
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
    justify-content: center;
    box-sizing: border-box;
  }
  @media (max-width: 575px) {
    .look-promo-card {
      grid-column: span 2;
    }
  }
  .look-promo-card i {
    font-size: 24px;
    color: #c5a880;
    margin-bottom: 12px;
  }
  .look-promo-card h4 {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 6px 0;
  }
  .look-promo-card p {
    font-size: 10px;
    line-height: 1.4;
    color: #666;
    margin: 0 0 15px 0;
  }
  .look-promo-btn {
    border: 1px solid #111;
    background: none;
    padding: 8px 16px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .look-promo-btn:hover {
    background-color: #111;
    color: #fff;
  }
</style>

<div class="angara-pdp">
  <!-- BREADCRUMBS -->
  <div class="angara-breadcrumbs">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/collections/all">Jewelry</a>
    <span>/</span>
    <a href="/collections/all">{{ product.type | default: 'Earrings' }}</a>
    <span>/</span>
    <span style="color: #111;">{{ product.title }}</span>
  </div>

  <div class="angara-grid">
    <!-- LEFT: GALLERY -->
    <section class="angara-gallery">
      <!-- Main Image Viewport -->
      <div class="angara-viewport">
        <span class="angara-tag">Made to Order</span>
        {% if product.handle == 'aurora-emerald-pear-diamond-stud-earrings' %}
          <img id="angara-main-img" src="{{ 'aurora_earrings_main.png' | asset_url }}" alt="{{ product.title | escape }}">
        {% elsif product.featured_image %}
          <img id="angara-main-img" src="{{ product.featured_image | img_url: '1200x' }}" alt="{{ product.title | escape }}">
        {% else %}
          <img id="angara-main-img" src="" alt="Placeholder">
        {% endif %}
      </div>

      <div class="angara-thumbs">
        <!-- If handle is our stud earrings, load the generated local asset as primary -->
        {% if product.handle == 'aurora-emerald-pear-diamond-stud-earrings' %}
          <div class="angara-thumb active" data-src="{{ 'aurora_earrings_main.png' | asset_url }}">
            <img src="{{ 'aurora_earrings_main.png' | asset_url }}" alt="{{ product.title | escape }}">
          </div>
          <div class="angara-thumb" data-src="{{ 'moments_ring_box.png' | asset_url }}">
