<style>
  /* Footer Trust Row */
  .footer-trust-row {
    background-color: #0a0a0a;
    color: #fff;
    padding: 30px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .footer-trust-item {
    display: flex;
    align-items: center;
    gap: 20px;
    border-right: 1px solid rgba(255, 255, 255, 0.12);
    padding-right: 20px;
  }
  .footer-trust-item:last-child {
    border-right: none;
    padding-right: 0;
  }
  .footer-trust-item svg {
    flex-shrink: 0;
  }
  .footer-trust-text {
    display: flex;
    flex-direction: column;
  }
  .footer-trust-text strong {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 6px;
    color: #fff;
    font-weight: 500;
  }
  .footer-trust-text span {
    font-family: var(--font-base), sans-serif;
    font-size: 11px;
    color: #aaa;
    line-height: 1.4;
    font-weight: 300;
  }

  @media (max-width: 991px) {
    .footer-trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px 20px;
    }
    .footer-trust-item {
      border-right: none;
      padding-right: 0;
    }
    .footer-trust-item:nth-child(2n-1) {
      border-right: 1px solid rgba(255, 255, 255, 0.12);
      padding-right: 20px;
    }
  }
  @media (max-width: 575px) {
    .footer-trust-grid {
      grid-template-columns: 1fr;
      gap: 25px;
    }
    .footer-trust-item, .footer-trust-item:nth-child(2n-1) {
      border-right: none;
      padding-right: 0;
    }
  }

  /* Footer Content */
  .arlena-footer {
    background-color: #000;
    color: #fff;
    padding: 60px 40px 30px 40px;
    font-family: var(--font-base);
  }
  .arlena-footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr) 1.5fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 40px;
  }
  .arlena-footer-col {
    display: flex;
    flex-direction: column;
  }
  .arlena-brand-col {
    gap: 20px;
  }
  .arlena-footer-logo {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 24px;
    letter-spacing: 4px;
    color: #fff;
  }
  .arlena-footer-desc {
    font-size: 12px;
    line-height: 1.6;
    color: #ccc;
    max-width: 250px;
  }
  .arlena-social-links {
    display: flex;
    gap: 15px;
    margin-top: 10px;
  }
  .arlena-social-links a {
    color: #fff;
    font-size: 16px;
    transition: color 0.3s ease;
  }
  .arlena-social-links a:hover {
    color: #c5a880;
  }
  .arlena-col-title {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 25px;
    color: #c5a880; /* Gold header for columns */
    font-weight: 600;
  }
  .arlena-footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .arlena-footer-col ul li a {
    font-size: 11px;
    color: #ccc;
    letter-spacing: 1px;
    text-decoration: none;
    transition: color 0.3s ease;
    text-transform: uppercase;
  }
  .arlena-footer-col ul li a:hover {
    color: #c5a880;
  }
  
  .arlena-newsletter-col {
    gap: 15px;
  }
  .arlena-newsletter-desc {
    font-size: 11px;
    line-height: 1.5;
    color: #ccc;
  }
  .arlena-newsletter-form {
    width: 100%;
    margin-top: 10px;
  }
  .arlena-newsletter-input-group {
    display: flex;
    border-bottom: 1px solid #fff;
    padding-bottom: 5px;
  }
  .arlena-newsletter-input-group input[type="email"] {
    background: none;
    border: none;
    color: #fff;
    flex: 1;
    font-size: 12px;
    outline: none;
    padding: 5px 0;
    font-family: inherit;
  }
  .arlena-newsletter-input-group input[type="email"]::placeholder {
    color: #777;
  }
  .arlena-newsletter-input-group button {
    background: none;
    border: none;
    color: #c5a880;
    cursor: pointer;
    padding: 5px;
    font-size: 14px;
    transition: transform 0.3s ease;
  }
  .arlena-newsletter-input-group button:hover {
    transform: translateX(3px);
  }

  /* Footer Bottom */
  .arlena-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 25px;
  }
  .copyright-text {
    font-size: 11px;
    color: #777;
  }
  .footer-legal-links {
    display: flex;
    gap: 20px;
  }
  .footer-legal-links a {
    font-size: 11px;
    color: #777;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .footer-legal-links a:hover {
    color: #c5a880;
  }

  @media (max-width: 991px) {
    .arlena-footer {
      padding: 40px 20px 20px 20px;
    }
    .arlena-footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
    .arlena-brand-col,
    .arlena-newsletter-col {
      grid-column: span 2;
    }
    .arlena-footer-bottom {
      flex-direction: column;
      gap: 15px;
      text-align: center;
    }
  }
  @media (max-width: 575px) {
    .arlena-footer-grid {
      grid-template-columns: 1fr;
    }
    .arlena-brand-col,
    .arlena-newsletter-col {
      grid-column: span 1;
    }
  }
</style>

<div class="footer-trust-row full-width">
