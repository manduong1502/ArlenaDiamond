<div class="contact-page full-width">
  <div class="contact-page-inner">

    <!-- ═══ PAGE TITLE ═══ -->
    <h1 class="contact-page-title">Contact Us</h1>

    <!-- ═══ EMAIL INFO ═══ -->
    <div class="contact-email-block">
      <h3 class="contact-info-label">EMAIL</h3>
      <p class="contact-info-value">
        <a href="mailto:{{ section.settings.email_address }}">{{ section.settings.email_address }}</a>
      </p>
      <p class="contact-info-hours">{{ section.settings.email_hours }}</p>
    </div>

    <div class="contact-divider"></div>

    <!-- ═══ DESCRIPTION ═══ -->
    <div class="contact-description">
      <p>At Arlena, our mission is to deliver exceptional service and ensure our customers' utmost satisfaction. Whether you have questions, feedback, or need assistance with your order, we're here to help.</p>
      <p>Please feel free to reach out to us at <a href="mailto:{{ section.settings.email_address }}">{{ section.settings.email_address }}</a> for any inquiries or concerns. Our dedicated team is ready to assist you and provide prompt and personalized support.</p>
    </div>

    <div class="contact-divider"></div>

    <!-- ═══ CONTACT FORM ═══ -->
    <div class="contact-form-wrap">
      {% form 'contact', class: 'contact-form' %}
        {% if form.posted_successfully? %}
          <!-- ═══ CREATIVE SUCCESS OVERLAY ═══ -->
          <div class="contact-success-overlay" id="contactSuccessOverlay">
            <div class="success-content">
              <div class="success-checkmark">
                <svg class="checkmark-svg" viewBox="0 0 52 52">
                  <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
                  <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                </svg>
              </div>
              <h3 class="success-title">Message Sent!</h3>
              <p class="success-text">Thank you for reaching out.<br>We'll get back to you shortly.</p>
              <a href="/pages/contact" class="success-btn">Send another message</a>
            </div>
            <!-- Confetti particles -->
            <div class="confetti-container" id="confettiContainer"></div>
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="contact-errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        {% unless form.posted_successfully? %}
        <div class="contact-form-row">
          <div class="contact-field">
            <input type="text" id="contact-name" name="contact[name]" placeholder="Your name" required>
          </div>
          <div class="contact-field">
            <input type="email" id="contact-email" name="contact[email]" placeholder="Your email" required>
          </div>
        </div>

        <div class="contact-field">
          <textarea id="contact-message" name="contact[body]" rows="8" placeholder="Your message" required></textarea>
        </div>

        <button type="submit" class="contact-submit">Send message</button>
        {% endunless %}
      {% endform %}
    </div>

  </div>
</div>

<style>
  .contact-page {
    background: #fff;
    min-height: 60vh;
  }
  .contact-page-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 120px 40px 80px;
  }

  /* ── Page Title ── */
  .contact-page-title {
    font-family: var(--font-base);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #111;
    margin: 0 0 40px 0;
    padding-bottom: 20px;
    border-bottom: 1px solid #e0e0e0;
  }

  /* ── Email Info ── */
  .contact-email-block {
    padding: 0;
    margin-bottom: 0;
  }
  .contact-info-label {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #111;
    margin: 0 0 10px 0;
  }
  .contact-info-value {
    font-size: 14px;
    color: #111;
    margin: 0 0 6px 0;
    line-height: 1.6;
  }
  .contact-info-value a {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .contact-info-value a:hover {
    color: #555;
  }
  .contact-info-hours {
    font-size: 13px;
    color: #555;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Divider ── */
  .contact-divider {
    border-top: 1px solid #e5e5e5;
    margin: 40px 0;
  }

  /* ── Description ── */
  .contact-description p {
    font-family: var(--font-base);
    font-size: 14px;
    line-height: 1.8;
    color: #333;
    margin: 0 0 16px 0;
  }
  .contact-description a {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Form ── */
  .contact-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .contact-field input,
  .contact-field textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #ccc;
    font-family: var(--font-base);
    font-size: 14px;
    color: #111;
    background: #fff;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .contact-field input::placeholder,
  .contact-field textarea::placeholder {
    color: #999;
    font-weight: 400;
  }
  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: #111;
  }
  .contact-field textarea {
    resize: vertical;
    margin-bottom: 20px;
  }
  .contact-submit {
    background: #111;
    color: #fff;
    border: none;
    padding: 14px 36px;
    font-family: var(--font-base);
    font-size: 13px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .contact-submit:hover {
    background: #333;
  }

  /* ── Success Overlay ── */
  .contact-success-overlay {
    position: relative;
    text-align: center;
    padding: 60px 20px 50px;
    animation: overlayFadeIn 0.6s ease-out;
    overflow: hidden;
  }
  @keyframes overlayFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .success-checkmark {
    width: 80px;
    height: 80px;
    margin: 0 auto 30px;
  }
  .checkmark-svg {
    width: 80px;
    height: 80px;
  }
  .checkmark-circle {
    stroke: #111;
    stroke-width: 2;
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    animation: strokeDraw 0.6s ease-out 0.3s forwards;
  }
  .checkmark-check {
    stroke: #111;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: strokeDraw 0.4s ease-out 0.8s forwards;
  }
  @keyframes strokeDraw {
    to { stroke-dashoffset: 0; }
  }

  .success-title {
    font-size: 26px;
    font-weight: 600;
    color: #111;
    margin: 0 0 12px;
    letter-spacing: 1px;
    opacity: 0;
    animation: textSlideUp 0.5s ease-out 1s forwards;
  }
  .success-text {
    font-size: 15px;
    color: #555;
    line-height: 1.7;
    margin: 0 0 30px;
    opacity: 0;
    animation: textSlideUp 0.5s ease-out 1.2s forwards;
  }
  @keyframes textSlideUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .success-btn {
    display: inline-block;
    padding: 12px 30px;
    background: #111;
    color: #fff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: background 0.2s;
    opacity: 0;
    animation: textSlideUp 0.5s ease-out 1.4s forwards;
  }
  .success-btn:hover {
    background: #333;
  }

  /* Confetti */
  .confetti-container {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
  }
  .confetti-piece {
    position: absolute;
    width: 8px;
    height: 8px;
    top: -10px;
    opacity: 0;
    animation: confettiFall 2.5s ease-out forwards;
  }
  @keyframes confettiFall {
    0% { opacity: 1; transform: translateY(0) rotate(0deg) scale(1); }
    100% { opacity: 0; transform: translateY(400px) rotate(720deg) scale(0.3); }
  }

  .contact-errors {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    padding: 14px 20px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .contact-page-inner {
      padding: 100px 20px 60px;
    }
    .contact-page-title {
      font-size: 20px;
      letter-spacing: 1px;
    }
    .contact-form-row {
      grid-template-columns: 1fr;
    }
    .success-checkmark { width: 60px; height: 60px; }
    .checkmark-svg { width: 60px; height: 60px; }
    .success-title { font-size: 22px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var container = document.getElementById('confettiContainer');
    if (!container) return;
    var colors = ['#111', '#e0e0e0', '#999', '#555', '#c8a96e', '#d4af37'];
    var shapes = ['circle', 'square', 'triangle'];
    for (var i = 0; i < 40; i++) {
      var piece = document.createElement('div');
      piece.className = 'confetti-piece';
      var color = colors[Math.floor(Math.random() * colors.length)];
      var shape = shapes[Math.floor(Math.random() * shapes.length)];
      piece.style.left = Math.random() * 100 + '%';
      piece.style.animationDelay = (Math.random() * 1.2 + 0.3) + 's';
      piece.style.animationDuration = (Math.random() * 1.5 + 2) + 's';
      if (shape === 'circle') {
        piece.style.borderRadius = '50%';
        piece.style.background = color;
      } else if (shape === 'square') {
        piece.style.background = color;
      } else {
        piece.style.width = '0';
        piece.style.height = '0';
        piece.style.background = 'none';
        piece.style.borderLeft = '5px solid transparent';
        piece.style.borderRight = '5px solid transparent';
        piece.style.borderBottom = '10px solid ' + color;
      }
      container.appendChild(piece);
    }
  });
</script>

{% schema %}
{
  "name": "Contact Us",
  "settings": [
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "hello@arlena.com.au"
    },
    {
      "type": "text",
      "id": "email_hours",
      "label": "Email Hours",
      "default": "(24/7)"
    }
  ],
  "presets": [{ "name": "Contact Us" }]
}
{% endschema %}
